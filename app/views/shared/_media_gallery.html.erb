<%# Renders a grid of attachments (images inline, video/audio players, files as
    download chips). Shared by the task page (all attachments) and the "What's
    New" changelog (image/video walkthrough media only). Local: `attachments`. %>
<div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
  <% attachments.each do |att| %>
    <% type = att.content_type.to_s %>
    <% if type.start_with?("image/") %>
      <a href="<%= url_for(att) %>" target="_blank" rel="noopener" class="block">
        <%= image_tag att, alt: att.filename.to_s, loading: "lazy",
              class: "h-28 w-full object-cover rounded-md border border-[color:var(--color-hair)]" %>
        <span class="block mt-1 text-xs text-[color:var(--color-ink-soft)] truncate"><%= att.filename %></span>
      </a>
    <% elsif type.start_with?("video/") %>
      <div>
        <video src="<%= url_for(att) %>" controls preload="metadata"
               class="h-28 w-full object-cover rounded-md border border-[color:var(--color-hair)] bg-black"></video>
        <span class="block mt-1 text-xs text-[color:var(--color-ink-soft)] truncate"><%= att.filename %></span>
      </div>
    <% elsif type.start_with?("audio/") %>
      <div class="col-span-2 sm:col-span-3">
        <audio src="<%= url_for(att) %>" controls preload="metadata" class="w-full"></audio>
        <span class="block mt-1 text-xs text-[color:var(--color-ink-soft)] truncate"><%= att.filename %></span>
      </div>
    <% else %>
      <a href="<%= url_for(att) %>" target="_blank" rel="noopener"
         class="flex items-center gap-2 p-2 rounded-md border border-[color:var(--color-hair)] hover:bg-[color:var(--color-paper-sunk)]">
        <span class="text-lg shrink-0" aria-hidden="true">📄</span>
        <span class="min-w-0">
          <span class="block text-xs font-medium text-[color:var(--color-ink)] truncate"><%= att.filename %></span>
          <span class="block text-[11px] text-[color:var(--color-ink-faint)]"><%= number_to_human_size(att.byte_size) %></span>
        </span>
      </a>
    <% end %>
  <% end %>
</div>
