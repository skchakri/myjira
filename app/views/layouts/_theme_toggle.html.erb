<%# Colour-theme toggle — Light / Auto / Dark segmented control. The theme
    controller persists the choice in localStorage and flips data-theme on
    <html>; an inline <head> script applies it before first paint. %>
<div class="flex items-center justify-between px-[10px] pt-2" data-controller="theme">
  <span class="eyebrow">Theme</span>
  <div class="theme-seg-group" role="group" aria-label="Colour theme">
    <button type="button" class="theme-seg" data-theme-target="option" data-theme-value="light"
            data-action="theme#select" aria-pressed="false" aria-label="Light theme" title="Light">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
      </svg>
    </button>
    <button type="button" class="theme-seg" data-theme-target="option" data-theme-value="auto"
            data-action="theme#select" aria-pressed="false" aria-label="Match system theme" title="Auto (match system)">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="2" y="4" width="20" height="13" rx="2"/><path d="M8 21h8M12 17v4"/>
      </svg>
    </button>
    <button type="button" class="theme-seg" data-theme-target="option" data-theme-value="dark"
            data-action="theme#select" aria-pressed="false" aria-label="Dark theme" title="Dark">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </button>
  </div>
</div>
