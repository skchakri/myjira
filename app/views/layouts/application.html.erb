<!DOCTYPE html>
<html class="h-full">
  <head>
    <title><%= content_for(:title) || "myjira" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>

    <%# Night mode: resolve the stored preference and set the theme on <html>
        synchronously, before first paint, so there is no flash of light mode. %>
    <script>
      (function () {
        try {
          var pref = localStorage.getItem("myjira-theme") || "auto";
          var dark = pref === "dark" ||
            (pref === "auto" && window.matchMedia("(prefers-color-scheme: dark)").matches);
          document.documentElement.setAttribute("data-theme", dark ? "dark" : "light");
        } catch (e) {
          document.documentElement.setAttribute("data-theme", "light");
        }
      })();
    </script>

    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full">
    <div class="flex min-h-screen" data-controller="client-filter">
      <!-- ========== Sidebar ========== -->
      <aside class="w-[260px] shrink-0 hair-r flex flex-col sticky top-0 h-screen">
        <!-- Brand -->
        <div class="px-4 pt-5 pb-4">
          <%= link_to root_path, class: "flex items-center gap-2.5 text-[color:var(--color-ink)]" do %>
            <svg class="h-7 w-7 shrink-0" viewBox="0 0 512 512" aria-hidden="true">
              <defs>
                <linearGradient id="mj-side-bg" x1="0" y1="0" x2="1" y2="1">
                  <stop offset="0" stop-color="#1A1814"/><stop offset="1" stop-color="#4A463E"/>
                </linearGradient>
                <linearGradient id="mj-side-ck" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0" stop-color="#E0A570"/><stop offset="1" stop-color="#B8502A"/>
                </linearGradient>
              </defs>
              <rect width="512" height="512" rx="112" fill="url(#mj-side-bg)"/>
              <rect x="136" y="176" width="40"  height="40"  rx="10" fill="#F7F4ED" fill-opacity="0.18"/>
              <rect x="200" y="184" width="176" height="24" rx="12" fill="#F7F4ED" fill-opacity="0.55"/>
              <rect x="136" y="240" width="40"  height="40"  rx="10" fill="#F7F4ED" fill-opacity="0.18"/>
              <rect x="200" y="248" width="140" height="24" rx="12" fill="#F7F4ED" fill-opacity="0.42"/>
              <rect x="136" y="304" width="40"  height="40"  rx="10" fill="#F7F4ED" fill-opacity="0.18"/>
              <rect x="200" y="312" width="160" height="24" rx="12" fill="#F7F4ED" fill-opacity="0.32"/>
              <path d="M148 194 l18 18 l30 -34" fill="none" stroke="url(#mj-side-ck)" stroke-width="18" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <div class="leading-tight">
              <div class="font-display text-[22px] tracking-tight">myjira</div>
              <div class="eyebrow mt-[2px]">testing · gaps · plans</div>
            </div>
          <% end %>
        </div>

        <!-- Global search — full-text across tasks, conversations & test results.
             Submits to /search (server-side); distinct from the client-side
             "Filter projects" box below, which only narrows the sidebar list. -->
        <div class="px-3 pb-2">
          <%= form_with url: search_path, method: :get do %>
            <label class="relative block">
              <span class="sr-only">Search everything</span>
              <svg class="absolute left-2.5 top-1/2 -translate-y-1/2 text-[color:var(--color-ink-faint)]" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
              <input
                type="search"
                name="q"
                value="<%= params[:controller] == 'search' ? params[:q] : nil %>"
                placeholder="Search everything"
                aria-label="Search everything"
                class="w-full pl-7 pr-3 py-1.5 text-sm bg-[color:var(--color-paper-raised)] hair-all rounded-md text-[color:var(--color-ink)] placeholder-[color:var(--color-ink-faint)] focus:border-[color:var(--color-amber-ink)] outline-none"
              />
            </label>
          <% end %>
        </div>

        <!-- Filter -->
        <div class="px-3 pb-2">
          <label class="relative block">
            <svg class="absolute left-2.5 top-1/2 -translate-y-1/2 text-[color:var(--color-ink-faint)]" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
            <input
              type="text"
              placeholder="Filter projects"
              data-client-filter-target="input"
              data-action="input->client-filter#filter keydown->client-filter#clear"
              class="w-full pl-7 pr-10 py-1.5 text-sm bg-[color:var(--color-paper-raised)] hair-all rounded-md text-[color:var(--color-ink)] placeholder-[color:var(--color-ink-faint)] focus:border-[color:var(--color-amber-ink)] outline-none"
            />
            <span class="absolute right-2 top-1/2 -translate-y-1/2 kbd">⌘K</span>
          </label>
        </div>

        <!-- Projects: their own nav section -->
        <div class="px-4 pt-3 pb-1.5 flex items-center justify-between shrink-0">
          <span class="eyebrow">Projects</span>
          <span class="eyebrow" data-client-filter-target="count"><%= sidebar_clients.size %></span>
        </div>

        <nav class="flex-1 overflow-y-auto px-2 pb-3">
          <% if sidebar_clients.empty? %>
            <div class="px-3 py-6 text-sm text-[color:var(--color-ink-faint)]">
              No projects yet.<br>
              <span class="text-[11px] font-mono">GET /c/&lt;slug&gt;</span> to create one.
            </div>
          <% end %>

          <% sidebar_clients_by_category.each do |cat, cat_projects| %>
            <div class="px-3 pt-2.5 pb-1 flex items-center justify-between" data-client-filter-target="cathead">
              <span class="eyebrow"><%= cat %></span>
              <span class="eyebrow"><%= cat_projects.size %></span>
            </div>
            <% cat_projects.each do |project|
                 health  = client_health(project)
                 active  = (params[:project_id] == project.slug && controller_name == "boards") ||
                           (params[:slug] == project.slug) ||
                           (params[:id] == project.slug && controller_name == "projects")
                 dot_cls, health_label = if health[:failing] || health[:critical_gaps].positive?
                             ["dot-fail", "failing"]
                           elsif health[:blocked] || health[:total_gaps].positive?
                             ["dot-block", "needs attention"]
                           elsif health[:plans].zero?
                             ["dot-idle", "no test plans"]
                           else
                             ["dot-pass", "healthy"]
                           end
            %>
              <%= link_to board_path(project),
                    class: "clink #{active ? 'clink-active' : ''}",
                    data: {
                      client_filter_target: "row",
                      hay: "#{project.name} #{project.slug} #{cat}"
                    } do %>
                <span class="dot <%= dot_cls %>" role="img" aria-label="Health: <%= health_label %>" title="Health: <%= health_label %>"></span>
                <span class="truncate"><%= project.name %></span>
                <% if health[:total_gaps].positive? %>
                  <span class="ml-auto text-[10.5px] tabular font-mono <%= health[:critical_gaps].positive? ? 'text-[color:var(--color-fail-ink)]' : 'text-[color:var(--color-ink-faint)]' %>">
                    <%= health[:total_gaps] %>
                  </span>
                <% else %>
                  <span class="clink-slug truncate max-w-[90px]"><%= project.slug %></span>
                <% end %>
              <% end %>
            <% end %>
          <% end %>

          <div class="hidden px-3 py-6 text-xs text-[color:var(--color-ink-faint)] text-center" data-client-filter-target="empty">
            No match.
          </div>
        </nav>

        <div class="my-1.5 mx-3 h-px shrink-0" style="background:var(--color-hair-soft);"></div>

        <!-- Channels: Browser Tasks + Conversations, grouped together -->
        <div class="px-4 pt-1 pb-1.5 shrink-0">
          <span class="eyebrow">Channels</span>
        </div>
        <nav class="px-2 pb-3 shrink-0">
          <%# Relay channel %>
          <% relay = browser_relay_stats
             relay_active = controller_name == "browser_tasks"
             relay_dot, relay_label = if relay[:waiting].positive? then ["dot-fail", "waiting on you"]
                         elsif relay[:open].positive? then ["dot-pass", "active"]
                         else ["dot-idle", "idle"]
                         end %>
          <%= link_to browser_tasks_path, class: "clink #{relay_active ? 'clink-active' : ''}" do %>
            <span class="dot <%= relay_dot %>" role="img" aria-label="Relay status: <%= relay_label %>" title="Relay status: <%= relay_label %>"></span>
            <span class="truncate">Browser Tasks</span>
            <% if relay[:open].positive? %>
              <span class="ml-auto text-[10.5px] tabular font-mono <%= relay[:waiting].positive? ? 'text-[color:var(--color-fail-ink)]' : 'text-[color:var(--color-ink-faint)]' %>">
                <%= relay[:open] %>
              </span>
            <% else %>
              <span class="clink-slug truncate max-w-[90px]">chrome</span>
            <% end %>
          <% end %>

          <%# Conversations hub — every CLI session, grouped by project %>
          <% convo_active = controller_name == "conversations" %>
          <%= link_to conversations_path, class: "clink #{convo_active ? 'clink-active' : ''}" do %>
            <span class="dot dot-idle" aria-hidden="true"></span>
            <span class="truncate">Conversations</span>
            <% if conversations_total.positive? %>
              <span class="ml-auto text-[10.5px] tabular font-mono text-[color:var(--color-ink-faint)]"><%= conversations_total %></span>
            <% else %>
              <span class="clink-slug truncate max-w-[90px]">cli</span>
            <% end %>
          <% end %>

          <%# Cross-project review queue — every in_review item in one place %>
          <% review_active = controller_name == "reviews"
             review_count  = review_queue_count %>
          <%= link_to review_path, class: "clink #{review_active ? 'clink-active' : ''}" do %>
            <span class="dot <%= review_count.positive? ? 'dot-pass' : 'dot-idle' %>" role="img" aria-label="Items awaiting review: <%= review_count %>" title="Items awaiting review: <%= review_count %>"></span>
            <span class="truncate">Review queue</span>
            <% if review_count.positive? %>
              <span class="ml-auto text-[10.5px] tabular font-mono text-[color:var(--color-pass-ink)]"><%= review_count %></span>
            <% else %>
              <span class="clink-slug truncate max-w-[90px]">prs</span>
            <% end %>
          <% end %>

          <%# Cross-project approvals inbox — items parked waiting on the human %>
          <% approvals_active = controller_name == "approvals"
             appr_count = approvals_count %>
          <%= link_to approvals_path, class: "clink #{approvals_active ? 'clink-active' : ''}" do %>
            <span class="dot <%= appr_count.positive? ? 'dot-pass' : 'dot-idle' %>" role="img" aria-label="Items awaiting you: <%= appr_count %>" title="Items awaiting you: <%= appr_count %>"></span>
            <span class="truncate">Approvals</span>
            <% if appr_count.positive? %>
              <span class="ml-auto text-[10.5px] tabular font-mono text-[color:var(--color-amber-ink)]"><%= appr_count %></span>
            <% else %>
              <span class="clink-slug truncate max-w-[90px]">inbox</span>
            <% end %>
          <% end %>
        </nav>

        <!-- Footer -->
        <div class="hair-t px-3 py-3 space-y-1">
          <%= link_to projects_path, class: "clink text-[12.5px]" do %>
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 7h18M3 12h18M3 17h18"/></svg>
            All projects
          <% end %>
          <a href="/api/v1/spec" target="_blank" class="clink text-[12.5px]">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="m7 8 5-4 5 4M7 16l5 4 5-4M12 4v16"/></svg>
            API spec
            <span class="clink-slug">json</span>
          </a>
          <div class="flex items-center justify-between px-[10px] pt-2 text-[10.5px] text-[color:var(--color-ink-faint)]">
            <span class="font-mono">localhost:1200</span>
            <span class="pill pill-quiet">local</span>
          </div>
          <%= render "layouts/theme_toggle" %>
        </div>
      </aside>

      <!-- ========== Main pane ========== -->
      <main class="flex-1 min-w-0" <%= tag.attributes(style: "--page-bg:#{content_for(:page_bg)};") if content_for?(:page_bg) %>>
        <% if notice.present? || alert.present? %>
          <div class="px-10 pt-6 -mb-2">
            <% if notice.present? %>
              <div class="paper flex items-center gap-3 px-4 py-2.5 text-sm">
                <span class="dot dot-pass" aria-hidden="true"></span><span><%= notice %></span>
              </div>
            <% end %>
            <% if alert.present? %>
              <div class="paper flex items-center gap-3 px-4 py-2.5 text-sm mt-2">
                <span class="dot dot-fail" aria-hidden="true"></span><span><%= alert %></span>
              </div>
            <% end %>
          </div>
        <% end %>

        <div class="px-10 py-8">
          <%= yield %>
        </div>
      </main>
    </div>
  </body>
</html>
