<% content_for :title, @project ? "#{@project.name} · sessions" : "Conversations" %>
<% content_for :page_bg, project_page_bg(@project) if @project %>

<div class="flex items-baseline justify-between mb-1">
  <div>
    <div class="eyebrow">Claude CLI history</div>
    <h1 class="text-2xl font-semibold tracking-tight text-[color:var(--color-ink)]">
      <%= @project ? "#{@project.name} · sessions" : "Conversations" %>
    </h1>
  </div>
  <div class="flex items-center gap-3">
    <% if @project %>
      <%= render "session_launches/new_button", project: @project %>
    <% else %>
      <div class="flex gap-1">
        <%= link_to "By folder", conversations_path,
              class: "pill #{@view == :grouped ? 'pill-accent' : 'pill-quiet'}" %>
        <%= link_to "Newest", conversations_path(view: "flat"),
              class: "pill #{@view == :flat ? 'pill-accent' : 'pill-quiet'}" %>
      </div>
      <span class="text-xs text-[color:var(--color-ink-faint)] tabular"><%= pluralize(conversations_total, "session") %></span>
    <% end %>
  </div>
</div>

<p class="text-sm text-[color:var(--color-ink-soft)] mb-4 max-w-2xl">
  Every Claude CLI session — your prompts, Claude's replies, and the actions it took —
  captured turn-by-turn. <strong>Grouped by client, newest first.</strong> Each folder has its own
  colour; click the ⚙ to recolour it.
</p>

<% if @project %>
  <%= render "agents/strip", project: @project %>
  <%= render "agent_schedules/list", project: @project %>
  <%= render "mcp_servers/strip", project: @project %>
<% end %>

<% unless @project %>
  <%# Live via Turbo Stream — the strip is pushed the instant any session syncs a
      turn. The frame's src + slow auto-reload is only a backstop that evicts
      sessions which have gone stale (no push can fire once activity stops). %>
  <%= turbo_stream_from "live_sessions" %>
  <%= turbo_frame_tag "live_sessions", src: live_conversations_path,
        data: { controller: "auto-reload", auto_reload_interval_value: 60000 } %>
<% end %>

<%# In-flight launches (queued / spawning / just-launched) — auto-refreshes so the
    attach command appears the moment the daemon spins the tmux window up. %>
<%= turbo_frame_tag "active_launches", src: active_session_launches_path,
      data: { controller: "auto-reload", auto_reload_interval_value: 5000 } %>

<%# In-flight MCP installs — same pattern, so a server flips to a configured pill
    the moment the daemon finishes `claude mcp add`. %>
<%= turbo_frame_tag "active_mcp_installs", src: active_mcp_installs_path,
      data: { controller: "auto-reload", auto_reload_interval_value: 5000 } %>

<% if @grouped %>
  <%# ---- Default: grouped by folder ---- %>
  <% if @grouped.empty? %>
    <%= card do %>
      <div class="py-10 text-center text-sm text-[color:var(--color-ink-faint)]">
        No conversations captured yet. They appear here automatically as you work in any project.
      </div>
    <% end %>
  <% else %>
    <div class="space-y-6">
      <% @grouped.each do |project, sessions| %>
        <% color = project_color(project)
           preview = sessions.first(ConversationsController::PER_PROJECT_PREVIEW) %>
        <section class="conv-group">
          <div class="conv-group-head relative flex items-center gap-2 mb-2 pb-1.5 hair-b">
            <span class="h-3 w-3 rounded-full shrink-0" style="background:<%= color %>;"></span>
            <%= link_to project.name, project_conversations_path(project),
                  class: "text-sm font-semibold hover:underline", style: "color:#{color};" %>
            <span class="text-[11px] text-[color:var(--color-ink-faint)] tabular"><%= sessions.size %></span>
            <%= render "session_launches/new_button", project: project %>
            <%= render "folder_gear", project: project %>
          </div>
          <% if project.branches.present? %>
            <div class="flex items-center flex-wrap gap-1.5 mb-2.5 -mt-0.5">
              <span class="text-[10px] uppercase tracking-wide text-[color:var(--color-ink-faint)]">branches</span>
              <% project.branches.first(6).each do |b| %>
                <span class="pill pill-quiet !py-0 !px-1.5 font-mono" title="<%= [b['subject'], b['rel']].compact.join(' · ') %>">⎇ <%= b["name"] %></span>
              <% end %>
              <%= link_to "all →", project_conversations_path(project),
                    class: "text-[10.5px] text-[color:var(--color-ink-faint)] hover:text-[color:var(--color-ink)]" %>
            </div>
          <% end %>
          <%= render "agents/strip", project: project, collapsed: true %>
          <%= render "mcp_servers/strip", project: project, collapsed: true %>
          <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-3 items-start">
            <% preview.each do |c| %>
              <%= render "conversation_card", c: c, show_folder: false, show_gear: false %>
            <% end %>
          </div>
          <% if sessions.size > preview.size %>
            <div class="mt-2 text-xs">
              <%= link_to "View all #{sessions.size} sessions in #{project.name} →",
                    project_conversations_path(project),
                    class: "text-[color:var(--color-ink-faint)] hover:text-[color:var(--color-ink)]" %>
            </div>
          <% end %>
        </section>
      <% end %>
    </div>
  <% end %>
<% elsif @conversations.empty? %>
  <%= card do %>
    <div class="py-10 text-center text-sm text-[color:var(--color-ink-faint)]">
      <%= @project ? "No sessions captured for this project yet." : "No sessions captured yet." %>
    </div>
  <% end %>
<% else %>
  <%# ---- Flat (Newest), or a single project's sessions ---- %>
  <% if @project&.branches.present? %>
    <div class="mb-4">
      <%= card title: "Recent branches" do %>
        <ul class="grid sm:grid-cols-2 gap-x-8 gap-y-1.5">
          <% @project.branches.first(12).each do |b| %>
            <li class="flex items-baseline gap-2 text-sm min-w-0">
              <span class="font-mono text-[color:var(--color-ink)] shrink-0">⎇ <%= b["name"] %></span>
              <span class="text-[11px] text-[color:var(--color-ink-faint)] truncate flex-1"><%= b["subject"] %></span>
              <span class="text-[11px] text-[color:var(--color-ink-faint)] tabular shrink-0"><%= b["rel"] %></span>
            </li>
          <% end %>
        </ul>
        <% if @project.branches_synced_at %>
          <p class="mt-2.5 text-[10.5px] text-[color:var(--color-ink-faint)]">synced <%= ago(@project.branches_synced_at) %></p>
        <% end %>
      <% end %>
    </div>
  <% end %>
  <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-3 items-start">
    <% @conversations.each do |c| %>
      <%= render "conversation_card", c: c, show_folder: true, show_gear: true %>
    <% end %>
  </div>
<% end %>
