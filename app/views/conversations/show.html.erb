<% content_for :title, @conversation.display_title %>
<% content_for :page_bg, project_page_bg(@project) %>

<%= turbo_stream_from [@conversation, :messages] %>
<%= turbo_stream_from [@conversation, :commands] %>
<%= turbo_stream_from [@conversation, :worklog] %>

<div class="flex items-baseline justify-between mb-4">
  <div class="min-w-0">
    <div class="text-xs text-[color:var(--color-ink-soft)] font-mono">
      <%= link_to @project.name, @project, class: "hover:underline" %> /
      <%= link_to "conversations", project_conversations_path(@project), class: "hover:underline" %> /
      <%= @conversation.session_id.first(8) %>
    </div>
    <div class="flex items-center gap-2">
      <h1 class="text-2xl font-semibold tracking-tight text-[color:var(--color-ink)] truncate"><%= @conversation.display_title %></h1>
      <details class="relative shrink-0">
        <summary class="grid place-items-center h-6 w-6 rounded-md cursor-pointer text-[color:var(--color-ink-faint)] hover:text-[color:var(--color-ink)] hover:bg-[color:var(--color-paper-sunk)]" title="Rename session">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
        </summary>
        <div class="absolute left-0 mt-1 w-72 paper rounded-lg shadow-xl p-3 z-30">
          <div class="eyebrow mb-1.5">Session name</div>
          <%= form_with url: rename_conversation_path(@conversation), method: :patch, class: "flex items-center gap-2" do |f| %>
            <%= f.text_field :name, value: @conversation.name, autofocus: true, placeholder: "e.g. profvault sitemap fix",
                  class: "flex-1 text-sm bg-[color:var(--color-paper-raised)] hair-all rounded-md px-2.5 py-1.5 text-[color:var(--color-ink)] placeholder-[color:var(--color-ink-faint)] focus:border-[color:var(--color-amber-ink)] outline-none" %>
            <%= f.submit "Save", class: "shrink-0 text-sm text-[color:var(--color-paper)] bg-[color:var(--color-amber-ink)] hover:bg-[color:var(--color-amber-ink-hover)] px-3 py-1.5 rounded-md cursor-pointer" %>
          <% end %>
          <p class="mt-1.5 text-[11px] text-[color:var(--color-ink-faint)]">Shows here and in your CLI status line. Clear it to revert to the auto title.</p>
        </div>
      </details>
    </div>
    <div class="mt-1 flex items-center gap-2 text-[11px] text-[color:var(--color-ink-faint)] font-mono flex-wrap">
      <% if @conversation.model.present? %><span class="pill pill-quiet"><%= @conversation.model %></span><% end %>
      <% if @conversation.model_deprecated? %>
        <span class="pill pill-block" title="Claude Code emitted a model-deprecation or out-of-policy warning for this session">&#9888; model deprecated</span>
      <% end %>
      <% if @conversation.git_branch.present? %><span>⎇ <%= @conversation.git_branch %></span><% end %>
      <% Array(@conversation.prs).each do |pr| %>
        <%= link_to "##{pr['number']} #{pr['draft'] ? 'draft' : pr['state']}", pr["url"], target: "_blank", rel: "noopener",
              title: pr["title"], class: "pill #{pr_pill_class(pr['state'], pr['draft'])} !py-0" %>
      <% end %>
      <% if @conversation.cwd.present? %><span class="truncate max-w-md"><%= @conversation.cwd %></span><% end %>
      <span><%= pluralize(@conversation.message_count, "turn") %></span>
    </div>
  </div>
</div>

<% if @conversation.highlights.present? %>
  <div class="mt-4">
    <%= card title: "What happened this session" do %>
      <ul class="space-y-1.5">
        <% @conversation.highlights.each do |h| %>
          <li class="flex items-start gap-2.5 text-sm text-[color:var(--color-ink)]">
            <span class="shrink-0 w-4 text-center text-[color:var(--color-ink-faint)]"><%= highlight_glyph(h["kind"]) %></span>
            <span><%= h["text"] %></span>
          </li>
        <% end %>
      </ul>
    <% end %>
  </div>
<% end %>

<div class="mt-4">
  <%= card title: "Worklog" do %>
    <%= render "worklog_events/timeline", subject: @conversation %>
  <% end %>
</div>

<% docs = @conversation.document_paths %>
<% if docs.any? %>
  <div class="mt-4">
    <%= card title: "Documents from this session" do %>
      <ul class="space-y-1.5">
        <% docs.each do |path| %>
          <li class="flex items-center gap-2.5 text-sm min-w-0">
            <span class="shrink-0 w-4 text-center text-[color:var(--color-ink-faint)]">▤</span>
            <%= link_to File.basename(path), document_conversation_path(@conversation, path: path),
                  target: "_blank", rel: "noopener", class: "ink-link shrink-0" %>
            <span class="truncate text-[11px] font-mono text-[color:var(--color-ink-faint)]"><%= File.dirname(path) %></span>
          </li>
        <% end %>
      </ul>
    <% end %>
  </div>
<% end %>

<% resume_cmd = @conversation.cwd.present? ?
     %(cd "#{@conversation.cwd}" && claude --resume #{@conversation.session_id}) :
     "claude --resume #{@conversation.session_id}" %>
<div class="mt-4" data-controller="clipboard">
  <%= card title: "Resume this session in your CLI" do %>
    <div class="flex items-start justify-between gap-3 mb-2">
      <p class="text-xs text-[color:var(--color-ink-soft)]">
        Run this in a terminal <strong>on the machine where this session lives</strong> to reopen it
        right where it left off (<code class="font-mono"><%= @conversation.session_id.first(8) %></code>).
        myjira can't launch the terminal for you, but this is the exact command.
      </p>
      <button type="button" data-clipboard-target="button" data-action="clipboard#copy"
              class="shrink-0 text-xs px-2 py-1 rounded-md border border-[color:var(--color-hair)] hover:bg-[color:var(--color-paper-sunk)] text-[color:var(--color-ink-soft)]">
        Copy command
      </button>
    </div>
    <pre data-clipboard-target="source" class="text-xs bg-[color:var(--color-paper-sunk)] text-[color:var(--color-ink)] rounded-md p-3 font-mono whitespace-pre-wrap"><%= resume_cmd %></pre>
  <% end %>
</div>

<%= render "conversations/summary_panel", conversation: @conversation %>

<div class="mt-4" data-controller="reset-form" data-action="turbo:submit-end->reset-form#reset">
  <%= card title: "Interact — send a command to this session" do %>
    <p class="text-xs text-[color:var(--color-ink-soft)] mb-2">
      Delivered to the live session if it's running <code class="font-mono text-[color:var(--color-ink)]">/myjira-listen</code> —
      it runs the command and posts the reply here. Works only while the session is <strong>live</strong>.
    </p>
    <%= form_with url: command_conversation_path(@conversation), method: :post,
          data: { controller: "file-input", action: "reset->file-input#clear" }, class: "mb-3" do |f| %>
      <div class="flex items-end gap-2">
        <label title="Attach image, video, or audio"
               class="shrink-0 grid place-items-center h-[42px] w-10 rounded-lg hair-all cursor-pointer text-[color:var(--color-ink-faint)] hover:text-[color:var(--color-amber-ink)] hover:bg-[color:var(--color-paper-sunk)]">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.44 11.05-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
          <%= f.file_field :files, multiple: true, accept: "image/*,video/*,audio/*",
                class: "hidden", data: { file_input_target: "input", action: "file-input#changed" } %>
        </label>
        <%= f.text_area :body, rows: 2,
              placeholder: "Type a command, and/or attach a file…",
              class: "flex-1 text-sm bg-[color:var(--color-paper-raised)] hair-all rounded-lg px-3 py-2 text-[color:var(--color-ink)] placeholder-[color:var(--color-ink-faint)] focus:border-[color:var(--color-amber-ink)] outline-none resize-y" %>
        <%= f.submit "Send", class: "shrink-0 text-sm text-[color:var(--color-paper)] bg-[color:var(--color-amber-ink)] hover:bg-[color:var(--color-amber-ink-hover)] px-4 py-2 rounded-lg cursor-pointer" %>
      </div>
      <p class="hidden mt-1 text-[11px] text-[color:var(--color-ink-faint)]" data-file-input-target="list"></p>
    <% end %>
    <div id="command_error_<%= @conversation.id %>"></div>
    <div id="session_commands_<%= @conversation.id %>">
      <% @commands.each do |c| %><%= render "session_commands/command", command: c %><% end %>
    </div>
  <% end %>
</div>

<div data-controller="chat">
  <%= card title: "Conversation" do %>
    <div data-chat-target="scroll" class="max-h-[72vh] overflow-y-auto -mx-1 px-1 pb-1">
      <div id="messages_<%= @conversation.id %>" class="space-y-3">
        <% @messages.each do |m| %>
          <%= render "conversation_messages/message", message: m %>
        <% end %>
      </div>
      <% if @messages.empty? %>
        <p class="text-sm text-[color:var(--color-ink-faint)] text-center py-8">
          No turns captured yet. They stream in here as the CLI session runs.
        </p>
      <% end %>
    </div>
  <% end %>
</div>

<% relays = @conversation.browser_tasks.order(created_at: :desc) %>
<% if relays.any? %>
  <div class="mt-4">
    <%= card title: "Relay tickets from this session" do %>
      <ul class="space-y-1.5">
        <% relays.each do |t| %>
          <li class="flex items-center gap-2.5 text-sm">
            <%= status_pill(t.status) %>
            <%= link_to t.title, browser_task_path(t), class: "ink-link truncate" %>
            <% if t.browser_session_id.present? %>
              <span class="ml-auto shrink-0 text-[10.5px] font-mono text-[color:var(--color-ink-faint)]"
                    title="Chrome session that handled it">chrome:<%= t.browser_session_id.first(8) %></span>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% end %>
  </div>
<% end %>
