<%# locals: c (conversation); show_folder (default true); show_gear (default true).
    The colour belongs to the FOLDER — shown on the folder dot + name, not as a
    decoration on the conversation card itself. %>
<% show_folder = local_assigns.fetch(:show_folder, true)
   show_gear   = local_assigns.fetch(:show_gear, true)
   color = project_color(c.project)
   # The folder's colour feeds a left "spine" on every card (--folder), so the
   # card reads as part of its group even before any tint is applied.
   card_styles = [ "--folder:#{color}" ]
   # Wash of the folder's colour. We pass the raw accent as --card-accent and
   # mix it against the themed paper token in CSS (.conv-card-tinted), so the
   # wash is a light tint on paper and a dark tint on the night canvas — the
   # --color-ink title is then readable in both modes.
   tinted = project_card_bg(c.project).present?
   card_styles << "--card-accent:#{color}" if tinted %>
<div class="conv-card paper relative rounded-xl p-4 <%= 'conv-card-tinted' if tinted %>" style="<%= card_styles.join(';') %>">

  <%# whole-card click target (sits under the content; gear opts back in) %>
  <%= link_to "".html_safe, conversation_path(c),
        class: "absolute inset-0 z-[1] rounded-xl", aria: { label: "Open #{c.display_title}" } %>

  <div class="relative z-[2] pointer-events-none">
    <div class="flex items-start justify-between gap-2">
      <h3 class="text-sm font-semibold text-[color:var(--color-ink)] leading-snug line-clamp-2">
        <%= c.display_title %>
      </h3>
      <% if show_gear %><%= render "folder_gear", project: c.project %><% end %>
    </div>

    <%# "Last context" — the most recent thing asked, so a long session reads as
        what it's doing now, not the prompt it opened with. Hidden when it would
        just echo the title. %>
    <% if c.last_context.present? && c.last_context != c.display_title %>
      <p class="mt-0.5 text-[11px] text-[color:var(--color-ink-faint)] leading-snug line-clamp-1">
        <span class="opacity-70">↳ last:</span> <%= c.last_context %>
      </p>
    <% end %>

    <div class="mt-2 flex items-center flex-wrap gap-x-2 gap-y-1 text-[11px] font-mono">
      <% if c.live? %>
        <span class="inline-flex items-center gap-1 font-sans font-semibold text-[color:var(--color-pass-ink)]">
          <span class="live-dot"></span>live
        </span>
      <% end %>
      <% if c.model_deprecated? %>
        <span class="pill pill-block !py-0 !px-1.5 font-sans pointer-events-none"
              title="Claude Code emitted a model-deprecation or out-of-policy warning for this session">&#9888; model deprecated</span>
      <% end %>
      <% if show_folder %>
        <span class="inline-flex items-center gap-1 font-sans font-semibold" style="color:<%= color %>;">
          <span class="h-2 w-2 rounded-full shrink-0" style="background:<%= color %>;"></span>
          <%= c.project.name %>
        </span>
      <% end %>
      <% if c.git_branch.present? %><span class="text-[color:var(--color-ink-faint)]">⎇ <%= c.git_branch %></span><% end %>
      <%# PR badges sit above the whole-card link so they stay individually clickable. %>
      <% Array(c.prs).first(2).each do |pr| %>
        <%= link_to "##{pr['number']}", pr['url'], target: "_blank", rel: "noopener",
              title: "#{pr['draft'] ? 'draft · ' : ''}#{pr['state']} — #{pr['title']}",
              class: "pill #{pr_pill_class(pr['state'], pr['draft'])} !py-0 !px-1.5 relative z-[3] pointer-events-auto" %>
      <% end %>
      <span class="text-[color:var(--color-ink-faint)]"><%= pluralize(c.message_count, "turn") %></span>
      <span class="ml-auto text-[color:var(--color-ink-faint)] tabular"><%= ago(c.last_message_at || c.created_at) %></span>
    </div>

    <%# What got done — a couple of bullets read off the captured tool actions. %>
    <% if Array(c.highlights).any? %>
      <ul class="mt-2 space-y-0.5">
        <% Array(c.highlights).first(3).each do |h| %>
          <li class="flex items-start gap-1.5 text-[11px] text-[color:var(--color-ink-soft)] leading-snug">
            <span class="shrink-0 text-[color:var(--color-ink-faint)] w-3 text-center"><%= highlight_glyph(h["kind"]) %></span>
            <span class="line-clamp-1"><%= h["text"] %></span>
          </li>
        <% end %>
      </ul>
    <% end %>
  </div>
</div>
