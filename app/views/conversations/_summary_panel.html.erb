<%# locals: conversation %>
<div class="mt-4" data-controller="speak">
  <%= card title: "Spoken summary" do %>
    <div class="flex items-center justify-between gap-3 mb-2">
      <p class="text-xs text-slate-500">Summarize this session and read it aloud (uses your browser's voice).</p>
      <div class="flex items-center gap-2">
        <%= form_with url: summarize_conversation_path(conversation), method: :post do |f| %>
          <button type="submit" data-action="speak#arm"
                  class="inline-flex items-center gap-1.5 text-sm text-white bg-[color:var(--color-amber-ink)] hover:bg-[color:var(--color-amber-ink-hover)] px-3 py-1.5 rounded-md cursor-pointer">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5 6 9H2v6h4l5 4V5z"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>
            Summarize &amp; speak
          </button>
        <% end %>
        <button type="button" data-action="speak#stop" data-speak-target="stop"
                class="hidden items-center gap-1.5 text-sm text-slate-600 border border-slate-300 hover:bg-slate-50 px-3 py-1.5 rounded-md cursor-pointer">
          ⏹ Stop
        </button>
      </div>
    </div>
    <div id="conversation_summary_<%= conversation.id %>" data-speak-target="panel">
      <%= render "conversations/summary_content", conversation: conversation %>
    </div>
  <% end %>
</div>
