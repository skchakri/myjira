<%# locals: conversation — inner content of the summary panel (replaced by the job) %>
<% if conversation.summary.present? %>
  <div class="flex items-center gap-1.5 mb-1.5 text-[11px] text-[color:var(--color-ink-faint)]">
    <span class="dot dot-pass" aria-hidden="true"></span>
    Summarized <%= conversation.summarized_at&.strftime("%-l:%M %p") %>
    <button type="button" data-action="speak#play"
            class="ml-1 inline-flex items-center gap-1 text-[color:var(--color-amber-ink)] hover:underline cursor-pointer">🔊 Play</button>
  </div>
  <p data-speak-target="text" class="text-sm leading-relaxed text-[color:var(--color-ink)]"><%= conversation.summary %></p>
<% else %>
  <p class="text-sm text-[color:var(--color-ink-faint)]">
    Click <span class="font-medium text-[color:var(--color-ink-soft)]">Summarize &amp; speak</span>
    for a short spoken recap of this session.
  </p>
<% end %>
