<%= form_with model: follow_up, url: follow_up.persisted? ? project_follow_up_task_path(@project, follow_up) : project_follow_up_tasks_path(@project), class: "max-w-2xl space-y-4" do |f| %>
  <% if follow_up.errors.any? %>
    <div class="rounded-md border border-[color:var(--color-fail-wash)] bg-[color:var(--color-fail-wash)] p-3 text-sm text-[color:var(--color-fail-ink)]">
      <ul class="list-disc ml-5"><% follow_up.errors.full_messages.each do |m| %><li><%= m %></li><% end %></ul>
    </div>
  <% end %>
  <div>
    <%= f.label :title, class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.text_field :title, class: "w-full rounded-md border-slate-300 text-sm" %>
  </div>
  <div>
    <%= f.label :description, class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.text_area :description, rows: 5, class: "w-full rounded-md border-slate-300 text-sm" %>
  </div>
  <div class="grid grid-cols-3 gap-4">
    <div>
      <%= f.label :kind, class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.select :kind, FollowUpTask::KINDS, {}, class: "w-full rounded-md border-slate-300 text-sm" %>
    </div>
    <div>
      <%= f.label :severity, class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.select :severity, FollowUpTask::SEVERITIES, {}, class: "w-full rounded-md border-slate-300 text-sm" %>
    </div>
    <div>
      <%= f.label :status, class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.select :status, FollowUpTask::STATUSES, {}, class: "w-full rounded-md border-slate-300 text-sm" %>
    </div>
  </div>
  <div>
    <%= f.label :task_id, "Related task", class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.select :task_id, @project.tasks.recent.limit(200).map { |t| [t.title, t.id] }, { include_blank: "— none —" }, class: "w-full rounded-md border-slate-300 text-sm" %>
  </div>
  <%= f.submit class: "inline-flex items-center rounded-md bg-slate-900 px-3 py-1.5 text-sm font-medium text-white hover:bg-slate-800 cursor-pointer" %>
<% end %>
