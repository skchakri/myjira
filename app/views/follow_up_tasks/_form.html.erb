<%= form_with model: follow_up, url: follow_up.persisted? ? project_follow_up_task_path(@project, follow_up) : project_follow_up_tasks_path(@project), class: "max-w-2xl space-y-4" do |f| %>
  <% if follow_up.errors.any? %>
    <div class="rounded-md border border-[color:var(--color-fail-wash)] bg-[color:var(--color-fail-wash)] p-3 text-sm text-[color:var(--color-fail-ink)]">
      <ul class="list-disc ml-5"><% follow_up.errors.full_messages.each do |m| %><li><%= m %></li><% end %></ul>
    </div>
  <% end %>
  <%= render "shared/field", form: f, attribute: :title, required: true %>
  <%= render "shared/field", form: f, attribute: :description, type: :textarea, rows: 5 %>
  <div class="grid grid-cols-3 gap-4">
    <%= render "shared/field", form: f, attribute: :kind, type: :select,
          choices: FollowUpTask::KINDS %>
    <%= render "shared/field", form: f, attribute: :severity, type: :select,
          choices: FollowUpTask::SEVERITIES %>
    <%= render "shared/field", form: f, attribute: :status, type: :select,
          choices: FollowUpTask::STATUSES %>
  </div>
  <%= render "shared/field", form: f, attribute: :task_id,
        label: "Related task", type: :select,
        choices: @project.tasks.recent.limit(200).map { |t| [t.title, t.id] },
        include_blank: "— none —" %>
  <%= f.submit class: "inline-flex items-center rounded-md bg-slate-900 px-3 py-1.5 text-sm font-medium text-white hover:bg-slate-800 cursor-pointer" %>
<% end %>
