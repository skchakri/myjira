<% content_for :title, @project.name %>

<div class="flex items-baseline justify-between mb-6">
  <div>
    <div class="text-xs text-slate-500 font-mono"><%= @project.slug %></div>
    <h1 class="text-2xl font-semibold tracking-tight text-slate-900"><%= @project.name %></h1>
    <% if @project.description.present? %>
      <p class="mt-1 text-sm text-slate-600 max-w-2xl"><%= @project.description %></p>
    <% end %>
  </div>
  <div class="flex items-center gap-2">
    <%= link_to "Edit", edit_project_path(@project), class: "text-sm text-slate-600 hover:text-slate-900 px-3 py-1.5 border border-slate-200 rounded-md" %>
    <%= link_to "+ Task", new_project_task_path(@project), class: "text-sm text-white bg-slate-900 hover:bg-slate-800 px-3 py-1.5 rounded-md" %>
    <%= link_to "+ Test plan", new_project_test_plan_path(@project), class: "text-sm text-white bg-emerald-700 hover:bg-emerald-800 px-3 py-1.5 rounded-md" %>
  </div>
</div>

<% rollup = @project.rollup %>
<div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
  <div class="rounded-xl border border-slate-200 bg-white p-4">
    <div class="text-2xl font-semibold text-slate-900"><%= rollup[:tasks] %></div>
    <div class="text-xs uppercase tracking-wide text-slate-500 mt-1">total tasks</div>
  </div>
  <div class="rounded-xl border border-slate-200 bg-white p-4">
    <div class="text-2xl font-semibold text-amber-700"><%= rollup[:open_tasks] %></div>
    <div class="text-xs uppercase tracking-wide text-slate-500 mt-1">open / in progress</div>
  </div>
  <div class="rounded-xl border border-slate-200 bg-white p-4">
    <div class="text-2xl font-semibold text-slate-900"><%= rollup[:test_plans] %></div>
    <div class="text-xs uppercase tracking-wide text-slate-500 mt-1">test plans</div>
  </div>
  <div class="rounded-xl border border-slate-200 bg-white p-4">
    <div class="text-2xl font-semibold text-rose-700"><%= rollup[:open_follow_ups] %></div>
    <div class="text-xs uppercase tracking-wide text-slate-500 mt-1">open gaps</div>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
  <div class="lg:col-span-2 space-y-4">
    <%= card title: "Tasks" do %>
      <% if @tasks.empty? %>
        <p class="text-sm text-slate-500">No tasks yet. Claude CLI can create one via <code class="font-mono text-xs bg-slate-100 px-1 rounded">POST /api/v1/projects/<%= @project.slug %>/tasks</code>.</p>
      <% else %>
        <div class="divide-y divide-slate-100">
          <% @tasks.each do |t| %>
            <div class="flex items-center justify-between py-2">
              <div class="min-w-0">
                <%= link_to t.title, [@project, t], class: "text-sm font-medium text-slate-900 hover:text-slate-700 truncate block" %>
                <div class="text-xs text-slate-500 mt-0.5 flex items-center gap-2">
                  <%= status_pill(t.status) %>
                  <% if t.environment %><span class="font-mono"><%= t.environment.name %></span><% end %>
                  <% if t.external_ref.present? %><span class="font-mono truncate"><%= t.external_ref %></span><% end %>
                </div>
              </div>
              <div class="text-xs text-slate-400"><%= time_ago_in_words(t.created_at) %> ago</div>
            </div>
          <% end %>
        </div>
      <% end %>
    <% end %>

    <%= card title: "Test plans" do %>
      <% if @plans.empty? %>
        <p class="text-sm text-slate-500">No plans yet. Create a plan spanning one or more tasks.</p>
      <% else %>
        <div class="divide-y divide-slate-100">
          <% @plans.each do |p| %>
            <div class="flex items-center justify-between py-2">
              <div>
                <%= link_to p.title, [@project, p], class: "text-sm font-medium text-slate-900 hover:text-slate-700" %>
                <div class="text-xs text-slate-500 mt-0.5 flex items-center gap-2">
                  <%= status_pill(p.status) %>
                  <span><%= pluralize(p.test_cases.count, "case") %></span>
                  <span><%= pluralize(p.tasks.count, "task") %></span>
                </div>
              </div>
              <% run = p.latest_run %>
              <% if run %>
                <div class="text-right">
                  <div class="text-xs text-slate-500">latest run</div>
                  <div class="flex items-center gap-2"><%= status_pill(run.status) %><span class="text-xs text-slate-500"><%= run.progress[:percent] %>%</span></div>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>

  <div class="space-y-4">
    <%= card title: "Environments" do %>
      <% if @project.environments.empty? %>
        <p class="text-sm text-slate-500">No environments.</p>
      <% else %>
        <ul class="space-y-2">
          <% @project.environments.order(:name).each do |e| %>
            <li class="text-sm">
              <div class="font-mono text-slate-900"><%= e.name %></div>
              <% if e.base_url.present? %><div class="text-xs text-slate-500"><%= e.base_url %></div><% end %>
            </li>
          <% end %>
        </ul>
      <% end %>
      <div class="mt-3"><%= link_to "+ Environment", new_project_environment_path(@project), class: "text-xs text-slate-600 hover:text-slate-900" %></div>
    <% end %>

    <%= card title: "Open follow-ups" do %>
      <% if @follow_ups.empty? %>
        <p class="text-sm text-slate-500">Nothing open.</p>
      <% else %>
        <ul class="space-y-2">
          <% @follow_ups.each do |f| %>
            <li>
              <div class="flex items-center gap-2 text-sm">
                <%= severity_pill(f.severity) %>
                <span class="text-slate-900 truncate"><%= f.title %></span>
              </div>
              <div class="text-xs text-slate-500 mt-0.5"><%= f.kind %> · <%= status_pill(f.status) %></div>
            </li>
          <% end %>
        </ul>
      <% end %>
      <div class="mt-3"><%= link_to "All follow-ups →", project_follow_up_tasks_path(@project), class: "text-xs text-slate-600 hover:text-slate-900" %></div>
    <% end %>
  </div>
</div>
