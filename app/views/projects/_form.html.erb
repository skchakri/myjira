<%= form_with model: project, class: "max-w-2xl space-y-4" do |f| %>
  <% if project.errors.any? %>
    <div class="rounded-md border border-[color:var(--color-fail-wash)] bg-[color:var(--color-fail-wash)] p-3 text-sm text-[color:var(--color-fail-ink)]">
      <%= pluralize(project.errors.count, "error") %> prevented saving:
      <ul class="list-disc ml-5 mt-1">
        <% project.errors.full_messages.each do |m| %><li><%= m %></li><% end %>
      </ul>
    </div>
  <% end %>

  <%= render "shared/field", form: f, attribute: :name, required: true %>
  <%= render "shared/field", form: f, attribute: :slug,
        placeholder: "auto-generated from name",
        input_class: "font-mono",
        hint: "lowercase / digits / dashes — used in URLs and API calls." %>
  <%= render "shared/field", form: f, attribute: :description, type: :textarea, rows: 3 %>

  <%= render "shared/field", form: f, attribute: :memory_preamble, type: :textarea, rows: 5,
        label: "Project memory",
        placeholder: "Durable notes prepended into every agent launch — conventions, where things live, gotchas…",
        hint: "Static preamble carried into every CLI session for this project. Learned facts accumulate automatically alongside it." %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <%= render "shared/field", form: f, attribute: :repo_path,
          placeholder: "/home/kalyan/platform/...",
          input_class: "font-mono" %>
    <%= render "shared/field", form: f, attribute: :default_base_url,
          placeholder: "http://localhost:3000",
          input_class: "font-mono" %>
    <%= render "shared/field", form: f, attribute: :category, type: :select,
          choices: Project::CATEGORIES,
          include_blank: "(auto from path)",
          hint: "workspace group shown in the sidebar." %>
  </div>

  <div class="flex items-start gap-2 pt-1">
    <%= f.check_box :listed, class: "mt-0.5 rounded border-[color:var(--color-hair)] text-[color:var(--color-amber-ink)] focus:ring-[color:var(--color-amber-ink)]" %>
    <div>
      <%= f.label :listed, "Pin to Clients sidebar", class: "block text-sm font-medium text-[color:var(--color-ink-soft)]" %>
      <p class="text-xs text-[color:var(--color-ink-faint)]">Always list this project in the sidebar, even before it has any tasks.</p>
    </div>
  </div>

  <div class="flex items-center gap-2 pt-2">
    <%= f.submit class: "inline-flex items-center rounded-md bg-[color:var(--color-amber-ink)] px-3 py-1.5 text-sm font-medium text-[color:var(--color-paper)] hover:bg-[color:var(--color-amber-ink-hover)] cursor-pointer" %>
    <%= link_to "Cancel", projects_path, class: "text-sm text-[color:var(--color-ink-soft)] hover:text-[color:var(--color-ink)] px-2" %>
  </div>
<% end %>
