<%= form_with model: project, class: "max-w-2xl space-y-4" do |f| %>
  <% if project.errors.any? %>
    <div class="rounded-md border border-rose-200 bg-rose-50 p-3 text-sm text-rose-800">
      <%= pluralize(project.errors.count, "error") %> prevented saving:
      <ul class="list-disc ml-5 mt-1">
        <% project.errors.full_messages.each do |m| %><li><%= m %></li><% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.text_field :name, class: "w-full rounded-md border-slate-300 shadow-sm focus:border-slate-500 focus:ring-slate-500 text-sm" %>
  </div>
  <div>
    <%= f.label :slug, class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.text_field :slug, placeholder: "auto-generated from name", class: "w-full rounded-md border-slate-300 shadow-sm focus:border-slate-500 focus:ring-slate-500 text-sm font-mono" %>
    <p class="mt-1 text-xs text-slate-500">lowercase / digits / dashes — used in URLs and API calls.</p>
  </div>
  <div>
    <%= f.label :description, class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.text_area :description, rows: 3, class: "w-full rounded-md border-slate-300 shadow-sm focus:border-slate-500 focus:ring-slate-500 text-sm" %>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <%= f.label :repo_path, class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.text_field :repo_path, placeholder: "/home/kalyan/platform/...", class: "w-full rounded-md border-slate-300 shadow-sm focus:border-slate-500 focus:ring-slate-500 text-sm font-mono" %>
    </div>
    <div>
      <%= f.label :default_base_url, class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.text_field :default_base_url, placeholder: "http://localhost:3000", class: "w-full rounded-md border-slate-300 shadow-sm focus:border-slate-500 focus:ring-slate-500 text-sm font-mono" %>
    </div>
    <div>
      <%= f.label :category, class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.select :category, Project::CATEGORIES, { include_blank: "(auto from path)" }, class: "w-full rounded-md border-slate-300 shadow-sm focus:border-slate-500 focus:ring-slate-500 text-sm" %>
      <p class="mt-1 text-xs text-slate-500">workspace group shown in the sidebar.</p>
    </div>
  </div>
  <div class="flex items-start gap-2 pt-1">
    <%= f.check_box :listed, class: "mt-0.5 rounded border-slate-300 text-slate-900 focus:ring-slate-500" %>
    <div>
      <%= f.label :listed, "Pin to Clients sidebar", class: "block text-sm font-medium text-slate-700" %>
      <p class="text-xs text-slate-500">Always list this project in the sidebar, even before it has any tasks.</p>
    </div>
  </div>
  <div class="flex items-center gap-2 pt-2">
    <%= f.submit class: "inline-flex items-center rounded-md bg-slate-900 px-3 py-1.5 text-sm font-medium text-white hover:bg-slate-800 cursor-pointer" %>
    <%= link_to "Cancel", projects_path, class: "text-sm text-slate-500 hover:text-slate-700 px-2" %>
  </div>
<% end %>
