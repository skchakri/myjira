<%# The project's folder path on disk, with copy-to-clipboard. `project` local. %>
<% if project.repo_path.present? %>
  <div data-controller="clipboard"
       class="mt-2 inline-flex items-center gap-2 max-w-full text-[11px] font-mono text-[color:var(--color-ink-faint)]">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" class="shrink-0" aria-hidden="true"><path d="M4 20h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.93a2 2 0 0 1-1.66-.9l-.82-1.2A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13c0 1.1.9 2 2 2Z"/></svg>
    <span class="sr-only">Project folder:</span>
    <span data-clipboard-target="source" class="truncate" title="<%= project.repo_path %>"><%= project.repo_path %></span>
    <button type="button" data-action="clipboard#copy" data-clipboard-target="button"
            class="shrink-0 underline decoration-dotted hover:text-[color:var(--color-amber-ink)] cursor-pointer"
            aria-label="Copy folder path to clipboard">copy</button>
  </div>
<% end %>
