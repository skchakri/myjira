<% content_for :title, "Projects" %>

<div class="flex items-baseline justify-between mb-6">
  <div>
    <h1 class="text-2xl font-semibold tracking-tight text-slate-900">Projects</h1>
    <p class="text-sm text-slate-500">Track tasks, plans, runs and gaps across everything you're building.</p>
  </div>
  <%= link_to "New project", new_project_path, class: "inline-flex items-center rounded-md bg-slate-900 px-3 py-1.5 text-sm font-medium text-white hover:bg-slate-800" %>
</div>

<% if @projects.empty? %>
  <%= card do %>
    <div class="text-center py-10">
      <p class="text-slate-500 text-sm">No projects yet. You can create one here, or from any Claude CLI session with:</p>
      <pre class="mt-3 mx-auto inline-block text-left text-xs bg-slate-900 text-slate-100 rounded-md px-4 py-3 font-mono">curl -X POST http://localhost:1200/api/v1/projects \
  -H "Content-Type: application/json" \
  -d '{"slug":"profvault","name":"ProfVault"}'</pre>
    </div>
  <% end %>
<% else %>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    <% @projects.each do |project| %>
      <%= link_to project, class: "group rounded-xl border border-slate-200 bg-white p-4 shadow-sm hover:shadow-md hover:border-slate-300 transition" do %>
        <div class="flex items-center justify-between">
          <h2 class="font-semibold text-slate-900 group-hover:text-slate-700"><%= project.name %></h2>
          <span class="text-xs font-mono text-slate-400"><%= project.slug %></span>
        </div>
        <p class="mt-2 text-sm text-slate-500 line-clamp-2"><%= project.description.presence || "No description." %></p>
        <% r = project.rollup %>
        <div class="mt-4 grid grid-cols-4 gap-2 text-center">
          <div><div class="text-lg font-semibold text-slate-900"><%= r[:tasks] %></div><div class="text-[11px] uppercase tracking-wide text-slate-400">tasks</div></div>
          <div><div class="text-lg font-semibold text-amber-700"><%= r[:open_tasks] %></div><div class="text-[11px] uppercase tracking-wide text-slate-400">open</div></div>
          <div><div class="text-lg font-semibold text-slate-900"><%= r[:test_plans] %></div><div class="text-[11px] uppercase tracking-wide text-slate-400">plans</div></div>
          <div><div class="text-lg font-semibold text-rose-700"><%= r[:open_follow_ups] %></div><div class="text-[11px] uppercase tracking-wide text-slate-400">gaps</div></div>
        </div>
      <% end %>
    <% end %>
  </div>
<% end %>
