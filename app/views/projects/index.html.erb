<% content_for :title, "Projects" %>
<%= turbo_stream_from :projects_overview %>

<div class="flex items-baseline justify-between mb-6">
  <div>
    <h1 class="text-2xl font-semibold tracking-tight text-[color:var(--color-ink)]">
      <%= @show_archived ? "Archived projects" : "Projects" %>
    </h1>
    <p class="text-sm text-[color:var(--color-ink-soft)]">
      <%= @show_archived ? "Retired folders, hidden from the sidebar. Unarchive to bring one back." : "Track tasks, plans, runs and gaps across everything you're building." %>
    </p>
  </div>
  <div class="flex items-center gap-3">
    <% if @show_archived %>
      <%= link_to "← Active projects", projects_path, class: "text-sm text-[color:var(--color-ink-soft)] hover:text-[color:var(--color-ink)]" %>
    <% elsif @archived_count.positive? %>
      <%= link_to projects_path(archived: 1), class: "text-sm text-[color:var(--color-ink-soft)] hover:text-[color:var(--color-ink)]" do %>
        Show archived <span class="text-[color:var(--color-ink-faint)]">(<%= @archived_count %>)</span>
      <% end %>
    <% end %>
    <%= link_to "New project", new_project_path, class: "inline-flex items-center rounded-md bg-[color:var(--color-amber-ink)] px-3 py-1.5 text-sm font-medium text-[color:var(--color-paper)] hover:bg-[color:var(--color-amber-ink-hover)]" %>
  </div>
</div>

<% if @projects.empty? %>
  <%= card do %>
    <div class="text-center py-10">
      <% if @show_archived %>
        <p class="text-[color:var(--color-ink-soft)] text-sm">No archived projects.</p>
      <% else %>
        <p class="text-[color:var(--color-ink-soft)] text-sm">No projects yet. You can create one here, or from any Claude CLI session with:</p>
        <pre class="mt-3 mx-auto inline-block text-left text-xs bg-[color:var(--color-paper-sunk)] text-[color:var(--color-ink)] rounded-md px-4 py-3 font-mono">curl -X POST http://localhost:1200/api/v1/projects \
  -H "Content-Type: application/json" \
  -d '{"slug":"profvault","name":"ProfVault"}'</pre>
      <% end %>
    </div>
  <% end %>
<% else %>
  <% projects_by_category(@projects).each do |cat, cat_projects| %>
    <div class="mt-7 first:mt-0 mb-3 flex items-center gap-2">
      <h2 class="text-xs font-semibold uppercase tracking-wider text-[color:var(--color-ink-soft)]"><%= cat %></h2>
      <span class="text-xs text-[color:var(--color-ink-faint)]"><%= cat_projects.size %></span>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      <% cat_projects.each do |project| %>
        <%= render "card", project: project %>
      <% end %>
    </div>
  <% end %>
<% end %>
