<%= form_with model: [@project, @plan, test_case], class: "max-w-3xl space-y-4" do |f| %>
  <% if test_case.errors.any? %>
    <div class="rounded-md border border-[color:var(--color-fail-wash)] bg-[color:var(--color-fail-wash)] p-3 text-sm text-[color:var(--color-fail-ink)]">
      <ul class="list-disc ml-5"><% test_case.errors.full_messages.each do |m| %><li><%= m %></li><% end %></ul>
    </div>
  <% end %>
  <%= render "shared/field", form: f, attribute: :title, required: true %>
  <%= render "shared/field", form: f, attribute: :steps,
        type: :textarea, rows: 6,
        input_class: "font-mono",
        placeholder: "1. ...\n2. ..." %>
  <%= render "shared/field", form: f, attribute: :expected_result,
        type: :textarea, rows: 3,
        input_class: "font-mono" %>
  <%= render "shared/field", form: f, attribute: :api_call,
        label: "API call / browser instruction (for automation)",
        type: :textarea, rows: 3,
        input_class: "font-mono",
        placeholder: "GET http://localhost:3000/users\nor: browser: click [data-test=\"submit\"]" %>
  <div class="grid grid-cols-2 gap-4">
    <%= render "shared/field", form: f, attribute: :task_id,
          label: "Associated task", type: :select,
          choices: @plan.tasks.map { |t| [t.title, t.id] },
          include_blank: "— none —" %>
    <%= render "shared/field", form: f, attribute: :position, type: :number %>
  </div>
  <%= f.submit class: "inline-flex items-center rounded-md bg-[color:var(--color-amber-ink)] px-3 py-1.5 text-sm font-medium text-[color:var(--color-paper)] hover:bg-[color:var(--color-amber-ink-hover)] cursor-pointer" %>
<% end %>
