<%# locals: project. Optional: agents (defaults to project.available_agents),
    collapsed (default false). The clickable catalogue of AI agents/skills/
    commands available in this folder's repo (plus globals), grouped by category.
    Each opens a small disclosure that triggers a fresh Claude session running it.
      collapsed=false → an always-open card with "New agent" / "Suggest agents"
                        controls (the focused project page).
      collapsed=true  → a discreet "◆ agents N" disclosure (the grouped hub,
                        where every folder gets one and space is tight). %>
<% agents    = local_assigns.fetch(:agents) { project.available_agents.to_a } %>
<% collapsed = local_assigns.fetch(:collapsed, false) %>
<%# One bulk query for the whole strip's launcher metrics — never per pill. %>
<% metrics   = Agent.metrics_for(agents) %>

<% if collapsed %>
  <% if agents.any? %>
    <details class="mb-2.5 -mt-0.5 group/agents">
      <summary class="inline-flex items-center gap-1.5 cursor-pointer list-none
                      text-[10px] uppercase tracking-wide text-[color:var(--color-ink-faint)]
                      hover:text-[color:var(--color-ink)]">
        <span class="font-mono text-[11px] text-[color:var(--color-amber-ink)]">◆</span> agents
        <span class="tabular"><%= agents.size %></span>
        <span class="group-open/agents:hidden">— click to run</span>
      </summary>
      <div class="flex flex-wrap gap-1.5 mt-1.5">
        <% agents.each do |agent| %>
          <%= render "agents/agent", agent: agent, project: project, metrics: metrics[agent.id] %>
        <% end %>
      </div>
    </details>
  <% end %>
<% else %>
  <section class="paper rounded-lg p-3 mb-4">
    <div class="flex items-center gap-2 mb-2.5">
      <span class="eyebrow">Agents in this folder</span>
      <span class="text-[11px] text-[color:var(--color-ink-faint)] tabular"><%= agents.size %></span>
      <div class="ml-auto flex items-center gap-1.5">
        <%= render "agents/new_button", project: project %>
        <%= render "agents/suggest_button", project: project %>
      </div>
    </div>

    <% if agents.any? %>
      <% Agent.grouped(agents).each do |label, list| %>
        <div class="mb-2.5 last:mb-0">
          <div class="text-[9.5px] uppercase tracking-wide text-[color:var(--color-ink-faint)] mb-1"><%= label %></div>
          <div class="flex flex-wrap gap-1.5">
            <% list.each do |agent| %>
              <%= render "agents/agent", agent: agent, project: project, metrics: metrics[agent.id] %>
            <% end %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="text-[11px] text-[color:var(--color-ink-faint)] leading-snug">
        No agents here yet. Use <span class="font-semibold">✚ New agent</span> or
        <span class="font-semibold">✨ Suggest agents</span> and Claude will write them into
        <span class="font-mono">.claude/agents/</span>.
      </p>
    <% end %>
  </section>
<% end %>
