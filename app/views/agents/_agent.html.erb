<%# locals: agent (Agent), project (Project). Optional: metrics (one entry from
    Agent.metrics_for — runs/succeeded/failed/last_run_at/sparkline). One
    triggerable entry: a pill that opens a small form to run this agent/skill/
    command in the project's repo, now annotated with its run history. Submitting
    posts to AgentTriggersController#trigger → SessionLaunch. %>
<% metrics = local_assigns[:metrics] %>
<% runs    = metrics ? metrics[:runs].to_i : 0 %>
<details class="relative group/agent shrink-0">
  <summary class="inline-flex items-center gap-1.5 h-7 px-2.5 rounded-md cursor-pointer list-none
                  text-[12px] hair-all bg-[color:var(--color-paper-raised)]
                  hover:border-[color:var(--color-amber-ink)]"
           title="<%= agent.description.to_s.truncate(200) %>">
    <span class="font-mono text-[color:var(--color-ink-faint)] group-hover/agent:text-[color:var(--color-amber-ink)]"><%= agent.glyph %></span>
    <span class="font-semibold text-[color:var(--color-ink)]"><%= agent.name %></span>
    <% if agent.scope == "global" %>
      <span class="text-[9px] uppercase tracking-wide text-[color:var(--color-ink-faint)]">global</span>
    <% end %>
    <% if runs.positive? %>
      <span class="ml-0.5 text-[9px] tabular text-[color:var(--color-ink-faint)] group-hover/agent:text-[color:var(--color-amber-ink)]"
            title="ran <%= runs %>× · <%= metrics[:succeeded] %> succeeded"><%= runs %>×</span>
    <% end %>
  </summary>

  <div class="absolute right-0 mt-1 w-[340px] max-w-[calc(100vw-2rem)] paper rounded-lg shadow-xl p-3 z-30 text-left">
    <div class="flex items-center gap-2 mb-1.5">
      <span class="font-mono text-[color:var(--color-amber-ink)]"><%= agent.glyph %></span>
      <span class="text-[12px] font-semibold text-[color:var(--color-ink)]"><%= agent.name %></span>
      <span class="ml-auto pill pill-quiet !py-0 !px-1.5"><%= agent.kind %></span>
    </div>
    <% if agent.description.present? %>
      <p class="text-[11px] text-[color:var(--color-ink-faint)] leading-snug mb-2 line-clamp-4"><%= agent.description %></p>
    <% end %>

    <% if metrics %>
      <div class="mb-2 flex items-center gap-2 rounded-md bg-[color:var(--color-paper-raised)] hair-all px-2 py-1.5">
        <% if runs.positive? %>
          <div class="text-[10.5px] leading-tight text-[color:var(--color-ink-faint)] tabular">
            ran <span class="text-[color:var(--color-ink)] font-semibold"><%= runs %></span>×
            · <span class="text-[color:var(--color-pass-ink)] font-semibold"><%= metrics[:succeeded] %>✓</span>
            <% failed = metrics[:failed].to_i + metrics[:cancelled].to_i %>
            <% if failed.positive? %>· <span class="text-[color:var(--color-fail-ink)] font-semibold"><%= failed %>✕</span><% end %>
            <% if metrics[:running].to_i.positive? %>· <span class="text-[color:var(--color-amber-ink)] font-semibold"><%= metrics[:running] %>•</span><% end %>
            <% if metrics[:last_run_at] %><br>last run <%= time_ago_in_words(metrics[:last_run_at]) %> ago<% end %>
          </div>
          <span class="ml-auto shrink-0"><%= render "agents/sparkline", data: metrics[:sparkline] %></span>
        <% else %>
          <span class="text-[10.5px] text-[color:var(--color-ink-faint)] italic">not run yet</span>
        <% end %>
      </div>
    <% end %>

    <%= form_with url: trigger_project_agent_path(project, agent), method: :post do |f| %>
      <%= hidden_field_tag :agent_id, agent.id %>
      <%= f.text_area :task, rows: 2,
            placeholder: agent.kind == "agent" ? "What should #{agent.name} do? (optional)" : "arguments (optional)",
            class: "w-full text-[12px] bg-[color:var(--color-paper-raised)] hair-all rounded-md px-2 py-1.5 text-[color:var(--color-ink)] placeholder-[color:var(--color-ink-faint)] focus:border-[color:var(--color-amber-ink)] outline-none resize-y" %>
      <div class="mt-2 flex items-center gap-1.5">
        <%= f.select :model, SessionLaunch::MODELS.map { |m| [m, m] },
              { selected: SessionLaunch::MODELS.include?(agent.model) ? agent.model : "default" },
              class: "text-[11px] bg-[color:var(--color-paper-raised)] hair-all rounded-md px-1.5 py-1 outline-none" %>
        <%= f.select :permission_mode, SessionLaunch::PERMISSION_MODES.map { |m| [m, m] },
              { selected: "bypassPermissions" },
              class: "text-[11px] bg-[color:var(--color-paper-raised)] hair-all rounded-md px-1.5 py-1 outline-none",
              title: "bypassPermissions lets the agent run hands-off (the daemon auto-confirms the safety prompt). Pick a safer mode to approve actions yourself in the tmux window." %>
        <%= f.submit "Run", class: "ml-auto shrink-0 text-[12px] text-white bg-[color:var(--color-amber-ink)] hover:bg-[color:var(--color-amber-ink-hover)] px-3 py-1 rounded-md cursor-pointer" %>
      </div>
      <div class="mt-2 flex items-center gap-1.5 pt-2 hair-t">
        <span class="text-[10px] uppercase tracking-wide text-[color:var(--color-ink-faint)] shrink-0">on cron</span>
        <%= text_field_tag :cron, nil, placeholder: "0 9 * * *", autocomplete: "off",
              title: "5-field cron · e.g. 0 9 * * * (daily 09:00), 0 9 * * 1-5 (weekdays), 0 * * * * (hourly)",
              class: "flex-1 min-w-0 text-[11px] font-mono bg-[color:var(--color-paper-raised)] hair-all rounded-md px-1.5 py-1 outline-none focus:border-[color:var(--color-amber-ink)]" %>
        <%= f.submit "Schedule", formaction: project_agent_schedules_path(project), formmethod: "post",
              class: "shrink-0 text-[12px] text-[color:var(--color-ink)] bg-[color:var(--color-paper-raised)] hair-all hover:border-[color:var(--color-amber-ink)] hover:text-[color:var(--color-amber-ink)] px-3 py-1 rounded-md cursor-pointer" %>
      </div>
    <% end %>

    <div class="mt-2 pt-2 hair-t flex items-center gap-2">
      <span class="text-[9.5px] uppercase tracking-wide text-[color:var(--color-ink-faint)]"><%= agent.category_label %></span>
      <% if agent.scope != "global" %>
        <%= button_to project_agent_path(project, agent), method: :delete,
              form: { data: { turbo_confirm: "Remove #{agent.name}? This deletes its .claude/agents file." } },
              class: "ml-auto text-[10.5px] text-[color:var(--color-ink-faint)] hover:text-[color:var(--color-fail-ink)] cursor-pointer" do %>
          ✕ remove
        <% end %>
      <% end %>
    </div>
  </div>
</details>
