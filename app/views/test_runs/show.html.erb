<% content_for :title, "Run #{@run.id.first(8)}" %>

<div class="flex items-baseline justify-between mb-4">
  <div>
    <div class="text-xs text-slate-500 font-mono">
      <%= link_to @project.name, @project, class: "hover:underline" %> /
      <%= link_to @plan.title, [@project, @plan], class: "hover:underline" %> /
      run · <%= @run.id.first(8) %>
    </div>
    <h1 class="text-2xl font-semibold tracking-tight text-slate-900">Test run</h1>
    <div class="mt-2 flex items-center gap-2">
      <%= status_pill(@run.status) %>
      <span class="text-xs text-slate-500">started <%= format_time(@run.started_at) %></span>
      <% if @run.completed_at %><span class="text-xs text-slate-500">completed <%= format_time(@run.completed_at) %></span><% end %>
      <% if @run.initiated_by.present? %><span class="text-xs font-mono text-slate-500">by <%= @run.initiated_by %></span><% end %>
    </div>
  </div>
  <% unless @run.completed_at %>
    <%= button_to "Mark complete", complete_test_run_path(@run), method: :post, class: "text-sm text-white bg-slate-900 hover:bg-slate-800 px-3 py-1.5 rounded-md" %>
  <% end %>
</div>

<div class="grid grid-cols-5 gap-2 mb-4">
  <% progress = @run.progress %>
  <div class="col-span-5 rounded-xl border border-slate-200 bg-white p-4">
    <div class="flex items-center justify-between text-sm mb-2">
      <span class="font-medium text-slate-900"><%= progress[:done] %> / <%= progress[:total] %> cases executed</span>
      <span class="text-slate-500"><%= progress[:percent] %>%</span>
    </div>
    <%= progress_bar(progress[:percent], passed: @run.passed_count, failed: @run.failed_count, total: @run.total_cases) %>
    <div class="mt-3 grid grid-cols-4 gap-2 text-center text-sm">
      <div><span class="text-emerald-700 font-semibold"><%= @run.passed_count %></span> <span class="text-slate-500 text-xs">passed</span></div>
      <div><span class="text-rose-700 font-semibold"><%= @run.failed_count %></span> <span class="text-slate-500 text-xs">failed</span></div>
      <div><span class="text-amber-700 font-semibold"><%= @run.blocked_count %></span> <span class="text-slate-500 text-xs">blocked</span></div>
      <div><span class="text-slate-600 font-semibold"><%= @run.skipped_count %></span> <span class="text-slate-500 text-xs">skipped</span></div>
    </div>
  </div>
</div>

<%= card title: "Per-case results" do %>
  <table class="w-full text-sm">
    <thead class="text-xs text-slate-500 text-left">
      <tr><th class="pb-2">#</th><th class="pb-2">Case</th><th class="pb-2">Status</th><th class="pb-2">Actual / notes</th></tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      <% @results.each do |r| %>
        <tr>
          <td class="py-2 text-xs font-mono text-slate-500 align-top"><%= r.test_case.position %></td>
          <td class="py-2 align-top">
            <div class="text-slate-900 font-medium"><%= r.test_case.title %></div>
            <% if r.test_case.api_call.present? %>
              <details class="mt-1">
                <summary class="cursor-pointer text-xs text-slate-500">api call</summary>
                <pre class="mt-1 text-xs font-mono bg-slate-50 p-2 rounded whitespace-pre-wrap"><%= r.test_case.api_call %></pre>
              </details>
            <% end %>
          </td>
          <td class="py-2 align-top"><%= status_pill(r.status) %></td>
          <td class="py-2 align-top text-slate-700 text-xs">
            <% if r.actual_result.present? %><div><%= r.actual_result %></div><% end %>
            <% if r.notes.present? %><div class="text-slate-500 mt-1"><%= r.notes %></div><% end %>
            <% if r.screenshot_url.present? %><a href="<%= r.screenshot_url %>" target="_blank" class="text-sky-600 hover:text-sky-800 text-xs">screenshot ↗</a><% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>

<% if @run.summary.present? %>
  <div class="mt-4">
    <%= card title: "Summary" do %>
      <pre class="whitespace-pre-wrap text-sm text-slate-800"><%= @run.summary %></pre>
    <% end %>
  </div>
<% end %>

<div class="mt-4">
  <%= card title: "API pointers" do %>
    <p class="text-xs text-slate-500 mb-2">For the Claude browser extension / CLI to push progress:</p>
    <pre class="text-xs bg-slate-900 text-slate-100 rounded-md p-3 font-mono whitespace-pre-wrap">PATCH /api/v1/test_runs/<%= @run.id %>/results/{test_case_id}
  body: {"status":"pass|fail|blocked|skipped","actual_result":"...","notes":"..."}
PATCH /api/v1/test_runs/<%= @run.id %>/complete
  body: {"summary":"..."}</pre>
  <% end %>
</div>
