<% content_for :title, "Start run" %>
<h1 class="text-xl font-semibold text-slate-900 mb-4">Start run for "<%= @plan.title %>"</h1>
<%= form_with model: [@project, @plan, @run], url: project_test_plan_test_runs_path(@project, @plan), class: "max-w-md space-y-4" do |f| %>
  <div>
    <%= f.label :environment_id, "Environment", class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.select :environment_id, @project.environments.order(:name).map { |e| [e.name, e.id] }, { include_blank: "— none —" }, class: "w-full rounded-md border-slate-300 text-sm" %>
  </div>
  <div>
    <%= f.label :initiated_by, "Initiated by", class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.text_field :initiated_by, placeholder: "claude-browser-extension", class: "w-full rounded-md border-slate-300 text-sm font-mono" %>
  </div>
  <%= f.submit "Start run", class: "inline-flex items-center rounded-md bg-emerald-700 px-3 py-1.5 text-sm font-medium text-white hover:bg-emerald-800 cursor-pointer" %>
<% end %>
