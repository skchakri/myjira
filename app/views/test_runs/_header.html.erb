<div id="run_header_<%= run.id %>" class="grid grid-cols-5 gap-2 mb-4">
  <% progress = run.progress %>
  <div class="col-span-5 rounded-xl border border-[color:var(--color-hair)] bg-[color:var(--color-paper-raised)] p-4">
    <div class="flex items-center justify-between text-sm mb-2">
      <span class="font-medium text-[color:var(--color-ink)]"><%= progress[:done] %> / <%= progress[:total] %> cases executed</span>
      <span class="text-[color:var(--color-ink-soft)]"><%= progress[:percent] %>%</span>
    </div>
    <%= progress_bar(progress[:percent], passed: run.passed_count, failed: run.failed_count, total: run.total_cases) %>
    <div class="mt-3 grid grid-cols-4 gap-2 text-center text-sm">
      <div><span class="text-[color:var(--color-pass-ink)] font-semibold"><%= run.passed_count %></span> <span class="text-[color:var(--color-ink-soft)] text-xs">passed</span></div>
      <div><span class="text-[color:var(--color-fail-ink)] font-semibold"><%= run.failed_count %></span> <span class="text-[color:var(--color-ink-soft)] text-xs">failed</span></div>
      <div><span class="text-[color:var(--color-block-ink)] font-semibold"><%= run.blocked_count %></span> <span class="text-[color:var(--color-ink-soft)] text-xs">blocked</span></div>
      <div><span class="text-[color:var(--color-skip-ink)] font-semibold"><%= run.skipped_count %></span> <span class="text-[color:var(--color-ink-soft)] text-xs">skipped</span></div>
    </div>
  </div>
</div>
