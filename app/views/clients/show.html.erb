<% content_for :title, "#{@project.name} — myjira" %>

<!-- ========== Hero ========== -->
<div class="flex items-end justify-between gap-6 rise rise-1">
  <div class="min-w-0">
    <div class="flex items-center gap-2 eyebrow">
      <%= link_to "clients", clients_path, class: "hover:text-[color:var(--color-ink)]" %>
      <span>/</span>
      <span class="text-[color:var(--color-ink-soft)]">/c/<%= @project.slug %></span>
    </div>
    <h1 class="font-display text-[56px] leading-[1.02] tracking-tight mt-2 truncate">
      <%= @project.name %>
    </h1>
    <% if @project.description.present? %>
      <p class="mt-2 text-[15px] text-[color:var(--color-ink-soft)] max-w-2xl"><%= @project.description %></p>
    <% end %>
    <%= render "projects/repo_path", project: @project %>
  </div>
  <div class="flex flex-col items-end gap-2 shrink-0">
    <div class="flex items-center gap-2">
      <%= link_to board_path(@project),
            class: "px-3 py-1.5 rounded-md text-sm font-medium bg-[color:var(--color-ink)] text-[color:var(--color-paper)] hover:bg-[color:var(--color-ink-soft)]" do %>
        ▦ Board
      <% end %>
      <%= link_to new_project_test_plan_path(@project), class: "pill pill-accent hover:brightness-95" do %>
        + test plan
      <% end %>
      <%= link_to new_project_task_path(@project), class: "pill pill-quiet hover:brightness-95" do %>
        + task
      <% end %>
    </div>
    <div class="flex items-center gap-3 text-[11px] font-mono text-[color:var(--color-ink-faint)]">
      <%= link_to "full project →", project_path(@project), class: "hover:text-[color:var(--color-ink)]" %>
      <span>·</span>
      <%= link_to "json", "/api/v1/clients/#{@project.slug}", target: "_blank", class: "hover:text-[color:var(--color-ink)]" %>
    </div>
  </div>
</div>

<!-- ========== Stats strip ========== -->
<div class="grid grid-cols-3 md:grid-cols-6 gap-px bg-[color:var(--color-hair)] hair-all rounded-md overflow-hidden mt-8 rise rise-2">
  <% [
    ["Plans",     @stats[:plans],       nil],
    ["Runs",      @stats[:runs_total],  nil],
    ["Passed",    @stats[:passed],      "pass"],
    ["Failed",    @stats[:failed],      @stats[:failed].positive? ? "fail" : nil],
    ["Blocked",   @stats[:blocked],     @stats[:blocked].positive? ? "block" : nil],
    ["Open gaps", @stats[:open_gaps],   @stats[:critical_gaps].positive? ? "fail" : (@stats[:open_gaps].positive? ? "block" : nil)]
  ].each do |label, value, tone| %>
    <div class="bg-[color:var(--color-paper-raised)] px-4 py-4">
      <div class="eyebrow"><%= label %></div>
      <div class="mt-1 font-display text-[32px] leading-none tabular <%=
        case tone
        when 'pass'  then 'text-[color:var(--color-pass-ink)]'
        when 'fail'  then 'text-[color:var(--color-fail-ink)]'
        when 'block' then 'text-[color:var(--color-block-ink)]'
        end %>"><%= value %></div>
    </div>
  <% end %>
</div>

<!-- ========== Split: plans + gaps ========== -->
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mt-8 rise rise-3">
  <!-- Test plans column -->
  <div class="lg:col-span-2">
    <div class="flex items-baseline justify-between mb-3">
      <h2 class="font-display text-[26px] tracking-tight">Test plans & runs</h2>
      <% if @plans.any? %>
        <div class="eyebrow"><%= @plans.size %> plan<%= 's' if @plans.size != 1 %></div>
      <% end %>
    </div>

    <% if @plans.empty? %>
      <div class="paper p-8 text-center">
        <p class="text-[15px] text-[color:var(--color-ink-soft)]">No test plans yet.</p>
        <p class="mt-2 text-xs text-[color:var(--color-ink-faint)] font-mono">
          POST /api/v1/projects/<%= @project.slug %>/test_plans
        </p>
        <div class="mt-4">
          <%= link_to "+ Create a test plan", new_project_test_plan_path(@project), class: "pill pill-accent" %>
        </div>
      </div>
    <% else %>
      <div class="space-y-4">
        <% @plans.each do |plan|
             run   = @latest_runs[plan]
             total = plan.test_cases.size
             pass  = run ? run.passed_count.to_i  : 0
             fail  = run ? run.failed_count.to_i  : 0
             blk   = run ? run.blocked_count.to_i : 0
             pend  = total - pass - fail - blk - (run ? run.skipped_count.to_i : 0)
             pct   = run ? run.progress[:percent] : 0
        %>
          <details class="paper group" <%= "open" if run && (fail > 0 || plan == @plans.first) %>>
            <summary class="list-none cursor-pointer px-5 py-4 flex items-start justify-between gap-5 hover:bg-[color:var(--color-paper-sunk)]/40 transition-colors">
              <div class="min-w-0 flex-1">
                <div class="flex items-center gap-2">
                  <svg class="text-[color:var(--color-ink-faint)] transition-transform group-open:rotate-90" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="m9 18 6-6-6-6"/></svg>
                  <%= link_to plan.title, project_test_plan_path(@project, plan), class: "font-display text-[22px] tracking-tight truncate hover:text-[color:var(--color-amber-ink)]" %>
                </div>
                <div class="mt-2 ml-5 flex items-center gap-2 flex-wrap text-xs text-[color:var(--color-ink-faint)]">
                  <%= status_pill(plan.status) %>
                  <span class="font-mono tabular"><%= pluralize(total, 'case') %></span>
                  <span>·</span>
                  <span class="font-mono tabular"><%= pluralize(plan.tasks.size, 'task') %></span>
                  <% if run %>
                    <span>·</span>
                    <span>last run <%= ago(run.started_at) %></span>
                  <% else %>
                    <span>·</span>
                    <span class="italic">never run</span>
                  <% end %>
                </div>
              </div>

              <% if run %>
                <div class="shrink-0 w-[200px] text-right">
                  <div class="flex items-center justify-end gap-2 mb-1.5">
                    <%= status_pill(run.status) %>
                    <span class="text-[11px] font-mono tabular text-[color:var(--color-ink-faint)]"><%= pct %>%</span>
                  </div>
                  <%= segmented_track(passed: pass, failed: fail, blocked: blk, total: total) %>
                  <div class="mt-1.5 flex justify-end gap-3 text-[10.5px] font-mono tabular">
                    <span class="<%= pass > 0 ? 'text-[color:var(--color-pass-ink)]' : 'text-[color:var(--color-ink-faint)]' %>"><%= pass %>✓</span>
                    <span class="<%= fail > 0 ? 'text-[color:var(--color-fail-ink)] font-semibold' : 'text-[color:var(--color-ink-faint)]' %>"><%= fail %>✗</span>
                    <span class="<%= blk  > 0 ? 'text-[color:var(--color-block-ink)]' : 'text-[color:var(--color-ink-faint)]' %>"><%= blk %>⊘</span>
                    <span class="<%= pend > 0 ? 'text-[color:var(--color-ink-soft)]' : 'text-[color:var(--color-ink-faint)]' %>"><%= pend %>○</span>
                  </div>
                </div>
              <% else %>
                <div class="shrink-0 text-xs italic text-[color:var(--color-ink-faint)]">
                  <%= link_to "+ start run", new_project_test_plan_test_run_path(@project, plan), class: "pill pill-quiet no-underline" %>
                </div>
              <% end %>
            </summary>

            <!-- Expanded: test cases list -->
            <div class="hair-t px-5 py-3 bg-[color:var(--color-paper-sunk)]/30">
              <% results_by_case = run ? run.test_results.includes(:test_case).index_by(&:test_case_id) : {} %>
              <% cases = plan.test_cases.order(:position) %>
              <% if cases.empty? %>
                <p class="text-xs italic text-[color:var(--color-ink-faint)] py-2">No cases in this plan yet.</p>
              <% else %>
                <ol class="space-y-1.5">
                  <% cases.each do |tc|
                       r = results_by_case[tc.id]
                       status = r&.status || "pending"
                  %>
                    <li class="flex items-center gap-3 text-[13px]">
                      <span class="w-6 font-mono text-[10.5px] text-[color:var(--color-ink-faint)] tabular text-right"><%= tc.position %></span>
                      <span class="shrink-0"><%= status_pill(status) %></span>
                      <span class="min-w-0 truncate text-[color:var(--color-ink-soft)]"><%= tc.title %></span>
                      <% if r && r.notes.present? %>
                        <span class="shrink-0 text-[10.5px] font-mono text-[color:var(--color-ink-faint)]">notes</span>
                      <% end %>
                    </li>
                  <% end %>
                </ol>
              <% end %>
              <% if run %>
                <div class="mt-3 pt-3 hair-t flex items-center justify-between text-xs">
                  <span class="text-[color:var(--color-ink-faint)] font-mono">run <%= run.id[0,8] %> · started <%= format_time(run.started_at) %></span>
                  <%= link_to "Open run →", test_run_path(run), class: "ink-link" %>
                </div>
              <% end %>
            </div>
          </details>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Gaps column -->
  <div>
    <div class="flex items-baseline justify-between mb-3">
      <h2 class="font-display text-[26px] tracking-tight">Gaps & actions</h2>
      <% if @open_gaps.any? %>
        <div class="eyebrow <%= @stats[:critical_gaps].positive? ? 'text-[color:var(--color-fail-ink)]' : '' %>">
          <%= @open_gaps.size %> open
        </div>
      <% end %>
    </div>

    <% if @open_gaps.empty? %>
      <div class="paper p-6 text-center">
        <div class="font-display text-[44px] leading-none">—</div>
        <p class="mt-2 text-sm text-[color:var(--color-ink-soft)]">Nothing open.</p>
        <p class="mt-1 text-[11px] text-[color:var(--color-ink-faint)]">Gaps appear here when logged against tasks or test results.</p>
      </div>
    <% else %>
      <div class="paper">
        <ul class="divide-y divide-[color:var(--color-hair-soft)]">
          <% @open_gaps.each do |g| %>
            <li class="px-4 py-3">
              <div class="flex items-start gap-2.5">
                <%= severity_pill(g.severity) %>
                <div class="min-w-0 flex-1">
                  <%= link_to edit_project_follow_up_task_path(@project, g), class: "block font-medium text-[14px] text-[color:var(--color-ink)] hover:text-[color:var(--color-amber-ink)] truncate" do %>
                    <%= g.title %>
                  <% end %>
                  <div class="mt-1 flex items-center gap-1.5 flex-wrap text-[11px] text-[color:var(--color-ink-faint)]">
                    <span class="font-mono"><%= g.kind %></span>
                    <span>·</span>
                    <%= status_pill(g.status) %>
                    <% if g.task_id %>
                      <span>·</span>
                      <%= link_to "task", project_task_path(@project, g.task_id), class: "font-mono hover:text-[color:var(--color-ink)]" %>
                    <% end %>
                    <% if g.test_result_id %>
                      <span>·</span>
                      <span class="italic">from run</span>
                    <% end %>
                    <span>·</span>
                    <span><%= ago(g.created_at) %></span>
                  </div>
                </div>
              </div>
            </li>
          <% end %>
        </ul>
        <div class="hair-t px-4 py-2.5 flex items-center justify-between text-xs">
          <%= link_to "All follow-ups →", project_follow_up_tasks_path(@project), class: "ink-link" %>
          <span class="font-mono text-[color:var(--color-ink-faint)]">sorted by severity</span>
        </div>
      </div>
    <% end %>

    <!-- URL card -->
    <div class="paper-sunk mt-6 p-4">
      <div class="eyebrow">Stable URL · pyr-docker</div>
      <div class="mt-2 font-mono text-[12px] text-[color:var(--color-ink)] break-all">
        http://localhost:1200/c/<%= @project.slug %>
      </div>
      <div class="mt-1 font-mono text-[11px] text-[color:var(--color-ink-faint)] break-all">
        /api/v1/clients/<%= @project.slug %>
      </div>
    </div>
  </div>
</div>
