<%# A matched conversation turn. record: ConversationMessage (conversation+project preloaded).
    Deep-links to the turn's anchor in the session transcript. %>
<% convo = record.conversation
   snippet = record.body.presence || (record.tool_name.present? ? "#{record.tool_name} tool call" : record.payload.to_s) %>
<div class="flex items-start gap-2 min-w-0">
  <%= link_to conversation_path(convo, anchor: "conversation_message_#{record.id}"),
        class: "text-sm font-medium text-[color:var(--color-ink)] hover:text-[color:var(--color-amber-ink)] hover:underline truncate" do %>
    <%= convo.display_title %>
  <% end %>
  <span class="ml-auto flex items-center gap-1.5 shrink-0">
    <% if record.kind == "tool" %>
      <span class="pill pill-quiet font-mono"><%= record.tool_name.presence || "tool" %></span>
    <% else %>
      <span class="pill pill-quiet"><%= record.display_role %></span>
    <% end %>
  </span>
</div>
<% if snippet.present? %>
  <p class="mt-1 text-[13px] text-[color:var(--color-ink-soft)] line-clamp-2"><%= truncate(snippet.squish, length: 200) %></p>
<% end %>
<div class="mt-1 text-[11px] text-[color:var(--color-ink-faint)] flex items-center gap-2">
  <span><%= convo.project.name %></span>
  <span class="opacity-40">·</span>
  <span title="<%= format_time(record.occurred_at || record.created_at) %>"><%= ago(record.occurred_at || record.created_at) %></span>
</div>
