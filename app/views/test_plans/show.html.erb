<% content_for :title, @plan.title %>

<div class="flex items-baseline justify-between mb-4">
  <div>
    <div class="text-xs text-[color:var(--color-ink-faint)] font-mono"><%= link_to @project.name, @project, class: "hover:underline" %> / test plan</div>
    <h1 class="text-2xl font-semibold tracking-tight text-[color:var(--color-ink)]"><%= @plan.title %></h1>
    <div class="mt-2 flex items-center gap-2">
      <%= status_pill(@plan.status) %>
      <span class="text-xs text-[color:var(--color-ink-faint)]"><%= pluralize(@cases.size, "case") %></span>
      <span class="text-xs text-[color:var(--color-ink-faint)]"><%= pluralize(@plan.tasks.count, "task") %></span>
    </div>
  </div>
  <div class="flex items-center gap-2">
    <%= link_to "Edit plan", edit_project_test_plan_path(@project, @plan), class: "text-sm text-[color:var(--color-ink-soft)] hover:text-[color:var(--color-ink)] px-3 py-1.5 border border-[color:var(--color-hair)] rounded-md" %>
    <%= link_to "+ Test case", new_project_test_plan_test_case_path(@project, @plan), class: "text-sm text-[color:var(--color-paper)] bg-[color:var(--color-amber-ink)] hover:bg-[color:var(--color-amber-ink-hover)] px-3 py-1.5 rounded-md" %>
    <%= link_to "▶ Start run", new_project_test_plan_test_run_path(@project, @plan), class: "text-sm text-[color:var(--color-paper)] bg-[color:var(--color-amber-ink)] hover:bg-[color:var(--color-amber-ink-hover)] px-3 py-1.5 rounded-md" %>
  </div>
</div>

<% if @plan.description.present? %>
  <%= card title: "Plan description" do %>
    <pre class="whitespace-pre-wrap text-sm text-[color:var(--color-ink)]"><%= @plan.description %></pre>
  <% end %>
<% end %>

<div class="mt-4 grid grid-cols-1 lg:grid-cols-3 gap-4">
  <div class="lg:col-span-2">
    <%= card title: "Test cases" do %>
      <% if @cases.empty? %>
        <p class="text-sm text-[color:var(--color-ink-faint)]">No cases yet. Claude CLI can bulk-upload them via
          <code class="font-mono text-xs bg-[color:var(--color-paper-sunk)] px-1 rounded">POST /api/v1/projects/<%= @project.slug %>/test_plans/<%= @plan.id %>/test_cases/bulk</code>.</p>
      <% else %>
        <ol class="space-y-3">
          <% @cases.each do |c| %>
            <li class="rounded-md border border-[color:var(--color-hair)] bg-[color:var(--color-paper-sunk)] p-3">
              <div class="flex items-start justify-between gap-3">
                <div class="min-w-0">
                  <div class="text-xs text-[color:var(--color-ink-faint)] font-mono">#<%= c.position %></div>
                  <div class="text-sm font-medium text-[color:var(--color-ink)]"><%= c.title %></div>
                  <% if c.steps.present? %>
                    <details class="mt-2 text-sm text-[color:var(--color-ink-soft)]">
                      <summary class="cursor-pointer text-xs text-[color:var(--color-ink-faint)]">Steps</summary>
                      <pre class="mt-1 whitespace-pre-wrap font-mono text-xs"><%= c.steps %></pre>
                    </details>
                  <% end %>
                  <% if c.expected_result.present? %>
                    <details class="mt-1 text-sm text-[color:var(--color-ink-soft)]">
                      <summary class="cursor-pointer text-xs text-[color:var(--color-ink-faint)]">Expected result</summary>
                      <pre class="mt-1 whitespace-pre-wrap font-mono text-xs"><%= c.expected_result %></pre>
                    </details>
                  <% end %>
                  <% if c.api_call.present? %>
                    <details class="mt-1 text-sm text-[color:var(--color-ink-soft)]">
                      <summary class="cursor-pointer text-xs text-[color:var(--color-ink-faint)]">API call / browser instruction</summary>
                      <pre class="mt-1 whitespace-pre-wrap font-mono text-xs bg-[color:var(--color-ink)] text-[color:var(--color-paper)] rounded p-2"><%= c.api_call %></pre>
                    </details>
                  <% end %>
                </div>
                <div class="flex flex-col items-end gap-2">
                  <% if c.task %>
                    <%= link_to c.task.title.truncate(30), [@project, c.task], class: "text-xs text-[color:var(--color-ink-faint)] hover:text-[color:var(--color-ink)]" %>
                  <% end %>
                  <%= link_to "Edit", edit_project_test_plan_test_case_path(@project, @plan, c), class: "text-xs text-[color:var(--color-ink-faint)] hover:text-[color:var(--color-ink)]" %>
                </div>
              </div>
            </li>
          <% end %>
        </ol>
      <% end %>
    <% end %>
  </div>

  <div class="space-y-4">
    <%= card title: "Tasks in this plan" do %>
      <% if @plan.tasks.empty? %>
        <p class="text-sm text-[color:var(--color-ink-faint)]">No tasks attached.</p>
      <% else %>
        <ul class="space-y-2">
          <% @plan.tasks.each do |t| %>
            <li class="text-sm">
              <%= link_to t.title, [@project, t], class: "text-[color:var(--color-ink)] hover:text-[color:var(--color-ink-soft)]" %>
              <div class="text-xs mt-0.5"><%= status_pill(t.status) %></div>
            </li>
          <% end %>
        </ul>
      <% end %>
    <% end %>

    <%= card title: "Runs" do %>
      <% if @runs.empty? %>
        <p class="text-sm text-[color:var(--color-ink-faint)]">No runs yet.</p>
      <% else %>
        <ul class="space-y-2">
          <% @runs.each do |r| %>
            <li>
              <%= link_to test_run_path(r), class: "block text-sm hover:bg-[color:var(--color-paper-sunk)] rounded p-2 -mx-2" do %>
                <div class="flex items-center justify-between">
                  <span class="font-mono text-xs text-[color:var(--color-ink-faint)]"><%= r.id.first(8) %></span>
                  <%= status_pill(r.status) %>
                </div>
                <div class="text-xs text-[color:var(--color-ink-faint)] mt-1">
                  <%= format_time(r.started_at) %> · <%= r.progress[:percent] %>%
                </div>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% end %>
    <% end %>
  </div>
</div>
