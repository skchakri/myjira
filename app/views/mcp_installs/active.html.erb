<%# In-flight MCP installs (queued / installing / just-finished) — auto-refreshes
    so a server flips to a configured pill the moment the daemon runs `claude mcp
    add`. Mirrors session_launches/active. %>
<%= turbo_frame_tag "active_mcp_installs" do %>
  <% if @installs.any? %>
    <div class="paper rounded-xl p-3 mb-5" style="border-left:4px solid var(--color-amber-ink);">
      <div class="flex items-center gap-2 mb-2.5">
        <span class="h-2 w-2 rounded-full shrink-0 animate-pulse" style="background:var(--color-amber-ink);"></span>
        <span class="eyebrow">Configuring MCP</span>
        <span class="text-[11px] text-[color:var(--color-ink-faint)] tabular"><%= @installs.size %></span>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
        <% @installs.each do |install| %>
          <%= render "mcp_installs/install", install: install %>
        <% end %>
      </div>
    </div>
  <% end %>
<% end %>
