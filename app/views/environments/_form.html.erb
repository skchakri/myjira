<%= form_with model: [@project, environment], class: "max-w-xl space-y-4" do |f| %>
  <% if environment.errors.any? %>
    <div class="rounded-md border border-[color:var(--color-fail-wash)] bg-[color:var(--color-fail-wash)] p-3 text-sm text-[color:var(--color-fail-ink)]">
      <ul class="list-disc ml-5"><% environment.errors.full_messages.each do |m| %><li><%= m %></li><% end %></ul>
    </div>
  <% end %>

  <%= render "shared/field", form: f, attribute: :name, required: true,
        placeholder: "dev, staging, prod...",
        input_class: "font-mono" %>
  <%= render "shared/field", form: f, attribute: :base_url,
        placeholder: "http://localhost:3000",
        input_class: "font-mono" %>
  <%= render "shared/field", form: f, attribute: :notes, type: :textarea, rows: 3 %>

  <%= f.submit class: "inline-flex items-center rounded-md bg-slate-900 px-3 py-1.5 text-sm font-medium text-white hover:bg-slate-800 cursor-pointer" %>
<% end %>
