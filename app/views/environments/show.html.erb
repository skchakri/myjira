<% content_for :title, @environment.name %>
<%= card title: @environment.name do %>
  <p class="text-sm text-[color:var(--color-ink-soft)]"><span class="font-medium">Base URL:</span> <span class="font-mono"><%= @environment.base_url %></span></p>
  <% if @environment.notes.present? %>
    <pre class="mt-3 text-sm text-[color:var(--color-ink-soft)] whitespace-pre-wrap"><%= @environment.notes %></pre>
  <% end %>
  <div class="mt-3 flex gap-2">
    <%= link_to "Edit", edit_project_environment_path(@project, @environment), class: "text-sm text-[color:var(--color-ink-soft)] hover:text-[color:var(--color-ink)]" %>
    <%= button_to "Delete", project_environment_path(@project, @environment), method: :delete, form: { data: { turbo_confirm: "Delete environment?" } }, class: "text-sm text-[color:var(--color-fail-ink)] hover:text-[color:var(--color-fail-ink)] bg-transparent" %>
  </div>
<% end %>
