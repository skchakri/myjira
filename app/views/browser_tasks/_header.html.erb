<div id="browser_task_header_<%= task.id %>" class="paper flex flex-wrap items-center gap-x-4 gap-y-2 px-4 py-3">
  <%= status_pill(task.status) %>
  <% if task.waiting_on_cli? %>
    <span class="inline-flex items-center gap-1.5 text-xs text-[color:var(--color-block-ink)]">
      <span class="dot dot-block"></span> waiting on Claude CLI
    </span>
  <% elsif task.waiting_on_browser? %>
    <span class="inline-flex items-center gap-1.5 text-xs text-[color:var(--color-amber-ink)]">
      <span class="dot dot-idle"></span> waiting on Claude-in-Chrome
    </span>
  <% end %>
  <span class="text-xs text-[color:var(--color-ink-soft)]"><%= task.browser_messages.size %> messages</span>
  <% if task.initiated_by.present? %>
    <span class="text-xs font-mono text-[color:var(--color-ink-soft)]">by <%= task.initiated_by %></span>
  <% end %>
  <span class="text-xs text-[color:var(--color-ink-faint)] ml-auto">updated <%= format_time(task.last_activity_at || task.updated_at) %></span>
</div>
