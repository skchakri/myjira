<% content_for :title, @task.title %>

<div class="flex items-baseline justify-between mb-4">
  <div>
    <div class="text-xs text-[color:var(--color-ink-soft)] font-mono">
      <%= link_to @project.name, @project, class: "hover:underline" %> /
      task · <%= @task.id.first(8) %>
    </div>
    <h1 class="text-2xl font-semibold tracking-tight text-[color:var(--color-ink)]"><%= @task.title %></h1>
    <div class="mt-2 flex items-center gap-2">
      <%= status_pill(@task.status) %>
      <span class="text-xs text-[color:var(--color-ink-soft)]">priority: <%= @task.priority %></span>
      <% if @task.environment %><span class="text-xs font-mono text-[color:var(--color-ink-soft)]">env: <%= @task.environment.name %></span><% end %>
      <% if @task.labels.present? %>
        <% @task.labels.each do |l| %><span class="pill pill-quiet font-mono !py-0 !px-1.5 !text-[10px]"><%= l %></span><% end %>
      <% end %>
      <% if @task.external_ref.present? %>
        <% if @task.external_url.present? %>
          <%= link_to "#{@task.external_ref} ↗", @task.external_url, target: "_blank", rel: "noopener", title: "View in Jira", class: "text-xs font-mono text-[color:var(--color-ink-soft)] hover:text-[color:var(--color-ink)] underline decoration-dotted" %>
        <% else %>
          <span class="text-xs font-mono text-[color:var(--color-ink-soft)]"><%= @task.external_ref %></span>
        <% end %>
      <% end %>
    </div>
  </div>
  <div class="flex items-center gap-2">
    <%= form_with url: board_item_path(@project, @task), method: :patch, scope: :task,
          data: { controller: "auto-submit" }, class: "flex items-center" do |f| %>
      <%= hidden_field_tag :return_to, "task" %>
      <%= f.select :board_state,
            options_for_select(Task::BOARD_STATES.map { |s| [Task::BOARD_STATE_LABELS[s], s] }, @task.board_state),
            {}, { data: { action: "change->auto-submit#submit" }, "aria-label": "Board status",
                  class: "text-sm border border-[color:var(--color-hair)] rounded-md px-2 py-1.5 text-[color:var(--color-ink-soft)]" } %>
    <% end %>
    <%= link_to "Edit", edit_project_task_path(@project, @task), class: "text-sm text-[color:var(--color-ink-soft)] hover:text-[color:var(--color-ink)] px-3 py-1.5 border border-[color:var(--color-hair)] rounded-md" %>
    <%= link_to "+ Follow-up", new_project_task_follow_up_path(@project, @task), class: "text-sm text-[color:var(--color-paper)] bg-[color:var(--color-fail-ink)] hover:bg-[color:var(--color-fail-ink)] px-3 py-1.5 rounded-md" %>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
  <div class="lg:col-span-2 space-y-4">
    <%= card title: "Original documentation" do %>
      <% if @task.description.present? %>
        <pre class="whitespace-pre-wrap text-sm text-[color:var(--color-ink)] font-mono leading-relaxed"><%= @task.description %></pre>
      <% else %>
        <p class="text-sm text-[color:var(--color-ink-soft)]">No description yet.</p>
      <% end %>
    <% end %>

    <% if @task.attachments.attached? %>
      <%= card title: "Attachments" do %>
        <%= render "shared/media_gallery", attachments: @task.attachments %>
      <% end %>
    <% end %>

    <%= card title: "Implementation notes" do %>
      <% if @task.implementation_notes.present? %>
        <pre class="whitespace-pre-wrap text-sm text-[color:var(--color-ink)] font-mono leading-relaxed"><%= @task.implementation_notes %></pre>
      <% else %>
        <p class="text-sm text-[color:var(--color-ink-soft)]">Claude CLI hasn't recorded any implementation notes yet.</p>
      <% end %>
    <% end %>

    <%= card title: "What's New blurb" do %>
      <p class="text-xs text-[color:var(--color-ink-soft)] mb-2">
        Plain-language summary for end-users. When set and this item is
        <span class="font-medium">Done</span>, it appears on the project's
        <%= link_to "What's New", project_changelog_path(@project), class: "underline decoration-dotted hover:text-[color:var(--color-ink)]" %> feed.
      </p>
      <%= form_with url: board_item_path(@project, @task), method: :patch, scope: :task, class: "space-y-2" do |f| %>
        <%= hidden_field_tag :return_to, "task" %>
        <%= f.text_area :changelog_summary, value: @task.changelog_summary, rows: 3,
              placeholder: "e.g. You can now see a “What's New” feed for each project, explaining recent changes in plain language.",
              "aria-label": "What's New blurb",
              class: "w-full text-sm border border-[color:var(--color-hair)] rounded-md px-3 py-2" %>
        <div class="text-right">
          <%= f.submit "Save blurb", class: "text-sm text-[color:var(--color-paper)] bg-[color:var(--color-amber-ink)] hover:bg-[color:var(--color-amber-ink-hover)] px-3 py-1.5 rounded-md cursor-pointer" %>
        </div>
      <% end %>
    <% end %>

    <%= card title: "Comments" do %>
      <% if @comments.any? %>
        <ul class="space-y-3 mb-4">
          <% @comments.each do |c| %>
            <li>
              <div class="flex items-baseline gap-2">
                <span class="text-xs font-medium text-[color:var(--color-ink-soft)]"><%= c.author %></span>
                <span class="text-xs text-[color:var(--color-ink-faint)]" title="<%= format_time(c.created_at) %>"><%= ago(c.created_at) %></span>
              </div>
              <p class="text-sm text-[color:var(--color-ink)] whitespace-pre-wrap mt-0.5"><%= c.body %></p>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="text-sm text-[color:var(--color-ink-soft)] mb-4">No comments yet.</p>
      <% end %>

      <%= form_with url: board_item_comments_path(@project, @task), method: :post, class: "space-y-2" do %>
        <%= text_area_tag "comment[body]", nil, rows: 2, placeholder: "Add a comment… (e.g. why you're moving this back to Pending)",
              "aria-label": "Add a comment",
              class: "w-full text-sm border border-[color:var(--color-hair)] rounded-md px-3 py-2" %>
        <div class="text-right">
          <%= submit_tag "Post", class: "text-sm text-[color:var(--color-paper)] bg-[color:var(--color-amber-ink)] hover:bg-[color:var(--color-amber-ink-hover)] px-3 py-1.5 rounded-md cursor-pointer" %>
        </div>
      <% end %>
    <% end %>

    <%= card title: "Test plans covering this task" do %>
      <% if @test_plans.empty? %>
        <p class="text-sm text-[color:var(--color-ink-soft)]">No plan covers this task yet.</p>
      <% else %>
        <ul class="divide-y divide-[color:var(--color-hair)]">
          <% @test_plans.each do |p| %>
            <li class="py-2 flex items-center justify-between">
              <%= link_to p.title, [@project, p], class: "text-sm font-medium text-[color:var(--color-ink)] hover:text-[color:var(--color-ink-soft)]" %>
              <%= status_pill(p.status) %>
            </li>
          <% end %>
        </ul>
      <% end %>
    <% end %>
  </div>

  <div class="space-y-4">
    <%= card title: "Timeline" do %>
      <dl class="space-y-1.5">
        <% board_item_timeline(@task).each do |label, t| %>
          <div class="flex items-baseline justify-between gap-3">
            <dt class="text-sm text-[color:var(--color-ink-soft)]"><%= label %></dt>
            <dd class="text-xs font-mono text-[color:var(--color-ink)]" title="<%= ago(t) %>"><%= format_time(t) %></dd>
          </div>
        <% end %>
      </dl>
    <% end %>

    <%= card title: "Run an agent on this item" do %>
      <% agents = @project.agents.enabled.ordered %>
      <% if agents.any? %>
        <p class="text-xs text-[color:var(--color-ink-faint)] mb-2">Launch an agent in this repo on this item. Its result is posted to the comments when it finishes.</p>
        <%= form_with url: trigger_project_agent_path(@project, agents.first), method: :post, class: "space-y-2" do |f| %>
          <%= hidden_field_tag :task_id, @task.id %>
          <%= select_tag :agent_id,
                options_for_select(agents.map { |a| ["#{a.glyph} #{a.name}", a.id] }),
                "aria-label": "Choose an agent to run",
                class: "w-full text-sm bg-[color:var(--color-paper-raised)] hair-all rounded-md px-2 py-1.5 text-[color:var(--color-ink)] outline-none focus:border-[color:var(--color-amber-ink)]" %>
          <%= f.text_area :task, rows: 2,
                placeholder: "What should it do? (optional — defaults to this item's title + description)",
                class: "w-full text-sm bg-[color:var(--color-paper-raised)] hair-all rounded-md px-2 py-1.5 text-[color:var(--color-ink)] placeholder-[color:var(--color-ink-faint)] outline-none focus:border-[color:var(--color-amber-ink)] resize-y" %>
          <div class="flex items-center gap-1.5">
            <%= select_tag :permission_mode,
                  options_for_select(SessionLaunch::PERMISSION_MODES.map { |m| [m, m] }, "bypassPermissions"),
                  "aria-label": "Permission mode",
                  title: "bypassPermissions runs the agent hands-off; pick a safer mode to approve actions yourself in the tmux window.",
                  class: "text-xs bg-[color:var(--color-paper-raised)] hair-all rounded-md px-1.5 py-1 outline-none" %>
            <%= f.submit "Run", class: "ml-auto text-sm text-white bg-[color:var(--color-amber-ink)] hover:bg-[color:var(--color-amber-ink-hover)] px-3 py-1.5 rounded-md cursor-pointer" %>
          </div>
        <% end %>
      <% else %>
        <p class="text-sm text-[color:var(--color-ink-faint)]">No agents discovered in this project yet. Run Claude in the repo so myjira learns its agents.</p>
      <% end %>
    <% end %>

    <%= card title: "Follow-ups & gaps" do %>
      <% if @follow_ups.empty? %>
        <p class="text-sm text-[color:var(--color-ink-soft)]">None.</p>
      <% else %>
        <ul class="space-y-3">
          <% @follow_ups.each do |f| %>
            <li>
              <div class="flex items-center gap-2">
                <%= severity_pill(f.severity) %>
                <span class="text-sm text-[color:var(--color-ink)] truncate"><%= f.title %></span>
              </div>
              <% if f.description.present? %><p class="text-xs text-[color:var(--color-ink-soft)] mt-1 line-clamp-2"><%= f.description %></p><% end %>
              <div class="text-xs text-[color:var(--color-ink-faint)] mt-1"><%= f.kind %> · <%= status_pill(f.status) %></div>
            </li>
          <% end %>
        </ul>
      <% end %>
    <% end %>

    <%= card title: "API pointers" do %>
      <p class="text-xs text-[color:var(--color-ink-soft)] mb-2">Commands for Claude CLI to run from any project:</p>
      <pre class="text-xs bg-[color:var(--color-paper-sunk)] text-[color:var(--color-ink)] rounded-md p-3 font-mono whitespace-pre-wrap">PATCH /api/v1/projects/<%= @project.slug %>/tasks/<%= @task.id %>
POST  /api/v1/projects/<%= @project.slug %>/tasks/<%= @task.id %>/follow_ups
POST  /api/v1/projects/<%= @project.slug %>/test_plans</pre>
    <% end %>
  </div>
</div>
