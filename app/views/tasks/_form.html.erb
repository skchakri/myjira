<%= form_with model: [@project, task], class: "max-w-3xl space-y-4" do |f| %>
  <% if task.errors.any? %>
    <div class="rounded-md border border-[color:var(--color-fail-wash)] bg-[color:var(--color-fail-wash)] p-3 text-sm text-[color:var(--color-fail-ink)]">
      <ul class="list-disc ml-5"><% task.errors.full_messages.each do |m| %><li><%= m %></li><% end %></ul>
    </div>
  <% end %>

  <%= render "shared/field", form: f, attribute: :title, required: true %>
  <%= render "shared/field", form: f, attribute: :description,
        label: "Original documentation / task description",
        type: :textarea, rows: 6,
        input_class: "font-mono",
        placeholder: "What Claude CLI was asked to implement — the original ask, acceptance criteria, etc." %>
  <%= render "shared/field", form: f, attribute: :implementation_notes,
        label: "Implementation notes",
        type: :textarea, rows: 5,
        input_class: "font-mono",
        placeholder: "What Claude CLI actually did — files changed, endpoints added, gotchas..." %>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <%= render "shared/field", form: f, attribute: :status, type: :select,
          choices: Task::STATUSES %>
    <%= render "shared/field", form: f, attribute: :priority, type: :select,
          choices: Task::PRIORITIES %>
    <%= render "shared/field", form: f, attribute: :environment_id,
          label: "Environment", type: :select,
          choices: @project.environments.order(:name).map { |e| [e.name, e.id] },
          include_blank: "— none —" %>
  </div>

  <%= render "shared/field", form: f, attribute: :external_ref,
        label: "External ref (PR link, branch, ticket)",
        input_class: "font-mono" %>

  <div class="flex items-center gap-2 pt-2">
    <%= f.submit class: "inline-flex items-center rounded-md bg-slate-900 px-3 py-1.5 text-sm font-medium text-white hover:bg-slate-800 cursor-pointer" %>
    <%= link_to "Cancel", @project, class: "text-sm text-slate-500 hover:text-slate-700 px-2" %>
  </div>
<% end %>
