<%
  role = message.role
  kind = message.kind
  mine = role == "user"
  when_at = (message.occurred_at || message.created_at)
%>

<% if kind == "tool" %>
  <%# Tool actions read as a compact, dimmed mono line — not a speech bubble. %>
  <%
    icon =
      case message.tool_name
      when "Bash"                          then "⚙"
      when "Edit", "Write", "NotebookEdit" then "✎"
      when "Read"                          then "▤"
      when "Grep", "Glob"                  then "⌕"
      when "Task"                          then "⌥"
      when "WebFetch", "WebSearch"         then "⊕"
      else                                      "›"
      end
  %>
  <div id="conversation_message_<%= message.id %>" class="flex items-start gap-2.5">
    <span class="shrink-0 w-7 grid place-items-center text-[color:var(--color-ink-faint)] text-xs mt-0.5"><%= icon %></span>
    <div class="min-w-0 flex-1">
      <% if (doc = message.document_path) %>
        <pre class="whitespace-pre-wrap break-words text-[12px] leading-relaxed font-mono text-[color:var(--color-ink-soft)] bg-[color:var(--color-paper-sunk)] hair-all rounded-lg px-2.5 py-1.5">Write <%= link_to doc, document_conversation_path(message.conversation_id, path: doc), target: "_blank", rel: "noopener", class: "ink-link", title: "Open #{File.basename(doc)}" %></pre>
      <% else %>
        <pre class="whitespace-pre-wrap break-words text-[12px] leading-relaxed font-mono text-[color:var(--color-ink-soft)] bg-[color:var(--color-paper-sunk)] hair-all rounded-lg px-2.5 py-1.5"><%= message.body %></pre>
      <% end %>
    </div>
  </div>
<% else %>
  <%
    avatar =
      if mine
        { mono: "You", style: "background:var(--color-ink-soft); color:var(--color-paper);" }
      else
        { mono: "Cl", style: "background:var(--color-amber-ink); color:#fff;" }
      end
    bubble =
      if mine
        "background:var(--color-ink); border-color:var(--color-ink); color:var(--color-paper);"
      else
        "background:var(--color-paper-raised); border-color:var(--color-hair); color:var(--color-ink);"
      end
  %>
  <div id="conversation_message_<%= message.id %>" data-controller="say"
       class="flex items-start gap-2.5 <%= mine ? 'flex-row-reverse' : 'flex-row' %>">
    <span class="shrink-0 mt-4 grid place-items-center rounded-full h-7 w-7 text-[9px] font-semibold tracking-tight select-none"
          style="<%= avatar[:style] %>"><%= avatar[:mono] %></span>

    <div class="min-w-0 max-w-[80%] flex flex-col <%= mine ? 'items-end' : 'items-start' %>">
      <div class="flex items-center gap-2 mb-1 <%= mine ? 'flex-row-reverse' : '' %>">
        <span class="text-[11px] font-semibold text-[color:var(--color-ink-soft)]"><%= message.display_role %></span>
        <span class="text-[10px] text-[color:var(--color-ink-faint)] tabular"><%= when_at.strftime("%-l:%M %p") %></span>
        <button type="button" data-action="say#toggle" data-say-target="btn"
                title="Speak this message" aria-label="Speak this message"
                class="say-btn grid place-items-center h-5 w-5 rounded-md text-[color:var(--color-amber-ink)] bg-[color:var(--color-amber-wash)] ring-1 ring-[color:var(--color-amber-ink)]/25 hover:text-white hover:bg-[color:var(--color-amber-ink)] cursor-pointer transition-colors">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5 6 9H2v6h4l5 4V5z"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>
        </button>
      </div>
      <div data-say-target="content"
           class="rounded-2xl border px-3.5 py-2.5 text-sm leading-relaxed shadow-sm text-left
                  <%= mine ? 'rounded-tr-sm' : 'rounded-tl-sm' %>"
           style="<%= bubble %>">
        <%= markdown(message.body) %>
      </div>
    </div>
  </div>
<% end %>
