<%= turbo_frame_tag "board_modal" do %>
  <div data-controller="modal" data-action="click->modal#backdrop"
       class="fixed inset-0 z-50 flex items-start justify-center p-6 overflow-y-auto" style="background: rgba(26,24,20,0.45)">
    <div class="paper w-full max-w-4xl mt-10" style="box-shadow: 0 24px 60px -20px rgba(26,24,20,0.5)">
      <header class="flex items-center justify-between px-4 py-2.5 hair-b">
        <div class="min-w-0">
          <div class="eyebrow">Pull request <%= "##{task.pr_number}" if task.pr_number %></div>
          <div class="text-sm font-medium truncate"><%= task.title %></div>
        </div>
        <div class="flex items-center gap-3 shrink-0">
          <% if task.pr_url.present? %>
            <%= link_to "Open on GitHub ↗", task.pr_url, target: "_blank", rel: "noopener", class: "pill pill-accent" %>
          <% end %>
          <button data-action="modal#close" class="text-lg leading-none px-1" aria-label="Close">✕</button>
        </div>
      </header>
      <div class="p-4 max-h-[72vh] overflow-y-auto">
        <% if task.branch_name.present? %>
          <div class="mb-2 text-[11px] font-mono text-[color:var(--color-ink-faint)]">
            ⎇ <%= task.branch_name %> → main · <%= task.pr_state || "open" %>
          </div>
        <% end %>
        <% if task.pr_diff.present? %>
          <pre class="text-xs leading-relaxed overflow-x-auto"
               style="background:#14110D; color:#F2ECE0; padding:1rem; border-radius:10px; border:1px solid rgba(255,255,255,0.08)"><%= task.pr_diff %></pre>
        <% else %>
          <p class="text-sm text-[color:var(--color-ink-faint)]">
            No diff captured.<%= " Open it on GitHub." if task.pr_url.present? %>
          </p>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
