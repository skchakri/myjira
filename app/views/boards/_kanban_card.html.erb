<% processing = inflight_launch&.task_id == item.id %>
<li data-sortable-item data-id="<%= item.id %>" draggable="true"
    class="px-2.5 py-2 cursor-grab <%= processing ? 'bg-[color:var(--color-amber-wash)] hover:bg-[color:var(--color-amber-wash)]' : 'bg-[color:var(--color-paper-raised)] hover:bg-[color:var(--color-paper-sunk)]' %>">
  <div class="flex items-center gap-1.5">
    <span data-sortable-handle role="button" tabindex="0"
          data-action="keydown->sortable#handleKey"
          aria-label="Reorder <%= item.title %> — use Up and Down arrow keys"
          class="text-[color:var(--color-ink-faint)] select-none rounded focus:outline-none focus:ring-2 focus:ring-[color:var(--color-amber-ink)]"
          title="Drag or use arrow keys to reprioritise">⠿</span>
    <%= item_type_chip(item.item_type) %>
    <% if item.over_budget? %><%= over_budget_badge %><% end %>
    <% if item.pr? %>
      <%= link_to "##{item.pr_number}", board_item_pr_path(item.project, item),
            data: { turbo_frame: "board_modal" }, class: "ml-auto pill #{pr_pill_class(item.pr_state)}" %>
    <% end %>
  </div>
  <%= link_to item.title, [item.project, item],
        class: "block mt-1 text-[13px] leading-snug text-[color:var(--color-ink)] hover:text-[color:var(--color-amber-ink)]" %>
  <div class="flex items-center gap-2 mt-1.5 text-[11px] text-[color:var(--color-ink-faint)]">
    <% if processing %>
      <span class="pill pill-accent flex items-center gap-1" style="font-size:10px;padding:1px 6px">
        <span class="live-dot" style="width:5px;height:5px"></span>
        running <%= inflight_launch.pipeline_step %>
      </span>
    <% end %>
    <% if item.has_plan? %>
      <%= link_to "📋", board_item_plan_path(item.project, item), data: { turbo_frame: "board_modal" }, title: "Plan" %>
    <% end %>
    <% if item.last_conversation %>
      <%= link_to "↗", conversation_path(item.last_conversation), title: "Session" %>
    <% end %>
    <% if item.last_test_run %><%= test_run_chip(item.last_test_run) %><% end %>
    <% if item.actionable? %>
      <%= button_to "▶", board_item_pick_up_path(item.project, item), method: :post,
            class: "ml-auto text-xs px-1.5 hair-all rounded cursor-pointer", title: "Pick up",
            "aria-label": "Pick up — run #{Board::Pipeline.next_step_for(item)} agent" %>
    <% elsif item.reviewable? %>
      <span class="ml-auto flex items-center gap-1">
        <% if item.resolving_conflicts? %>
          <span class="text-xs text-[color:var(--color-amber-ink)] animate-pulse" title="Resolving conflicts — an agent is merging main and re-merging the PR" aria-label="Resolving conflicts">⚠</span>
        <% elsif item.conflicting? %>
          <%= button_to "⚠", board_item_resolve_conflicts_path(item.project, item), method: :post,
                form: { data: { turbo_confirm: "Resolve conflicts and merge PR ##{item.pr_number}? An agent will merge main, resolve conflicts, lint+test, then squash-merge." } },
                class: "text-xs px-1.5 py-0.5 hair-all rounded text-[color:var(--color-amber-ink)] hover:bg-[color:var(--color-amber-wash)] cursor-pointer",
                title: "PR conflicts with main — Resolve & merge" %>
        <% elsif item.merge_requested? %>
          <span class="text-xs text-[color:var(--color-amber-ink)] animate-pulse" title="Merging on GitHub… moves to Done when confirmed" aria-label="Merging">⋯</span>
        <% else %>
          <%= button_to "✓", board_item_merge_path(item.project, item), method: :post,
                form: { data: { turbo_confirm: "Approve and merge PR ##{item.pr_number}? It will merge on GitHub and move to Done." } },
                class: "text-xs px-1.5 py-0.5 hair-all rounded text-[color:var(--color-pass-ink)] hover:bg-[color:var(--color-pass-wash)] cursor-pointer",
                title: "Approve & merge PR → Done" %>
          <%= button_to "✕", board_item_reject_path(item.project, item), method: :post,
                form: { data: { turbo_confirm: "Reject PR ##{item.pr_number}? It moves to Failed (the PR stays open on GitHub)." } },
                class: "text-xs px-1.5 py-0.5 hair-all rounded text-[color:var(--color-fail-ink)] hover:bg-[color:var(--color-fail-wash)] cursor-pointer",
                title: "Reject PR → Failed" %>
        <% end %>
      </span>
    <% end %>
  </div>
  <div class="mt-1.5 text-[10px] text-[color:var(--color-ink-faint)]">
    <%= board_item_times(item) %>
  </div>
</li>
